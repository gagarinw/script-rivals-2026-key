    local F = Instance.new("Frame", SG); F.Size = UDim2.new(0, 300, 0, 160); F.Position = UDim2.new(0.5, -150, 0.5, -80); F.BackgroundColor3 = Colors.Background; Instance.new("UICorner", F)
    local T = Instance.new("TextBox", F); T.Size = UDim2.new(0.8, 0, 0, 40); T.Position = UDim2.new(0.1, 0, 0.2, 0); T.PlaceholderText = "Введите ключ..."; T.BackgroundColor3 = Color3.fromRGB(30, 30, 30); T.TextColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", T)
    local B = Instance.new("TextButton", F); B.Size = UDim2.new(0.8, 0, 0, 40); B.Position = UDim2.new(0.1, 0, 0.6, 0); B.Text = "ВОЙТИ"; B.BackgroundColor3 = Colors.MainBlue; B.TextColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", B)
    
    if canSave and isfile(KEY_FILE) then
        local k = readfile(KEY_FILE)
        if VerifyKey(k) == "ok" then SG:Destroy(); BuildMenu() return end
    end

    B.MouseButton1Click:Connect(function()
        if VerifyKey(T.Text) == "ok" then SG:Destroy(); BuildMenu() else B.Text = "ОШИБКА"; task.wait(1); B.Text = "ВОЙТИ" end
    end)
end

-- [[ УПРАВЛЕНИЕ ]] --
UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Settings.MenuKey then if MainFrame then MainFrame.Parent.Enabled = not MainFrame.Parent.Enabled end end
    if i.KeyCode == Settings.AimKey then AimActive = true end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.KeyCode == Settings.AimKey then AimActive = false end
end)

ShowLogin()
