-- [[ ILLIA SYSTEM V3 - SERVER SYNC & CLEAN UI ]] --

local API_URL = "https://script.google.com/macros/s/AKfycbyeA-rWBrLS6otVeDtjQvSf3Dfu_0OhX3BHFdq-4M42OYz6aDUy71BO7gARj-fsySztgQ/exec"
local HttpService = game:GetService("HttpService")

local canSave = (isfile and readfile and writefile and delfile)
local KEY_FILE = "illia_v3_key.txt"
local SETTINGS_FILE = "illia_v3_settings.json"

local Settings = {
    AimbotEnabled = true,
    AimRadius = 150,
    Sensitivity = 0.1,
    AimKey = "E",
    ShowFOV = true,
    ESP_Enabled = true,
    ESP_Rainbow = false,
    ESP_Hue = 0.6
}

local function SaveSettings()
    if canSave then writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings)) end
end

local function LoadSettings()
    if canSave and isfile(SETTINGS_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
        if success then for k, v in pairs(data) do Settings[k] = v end end
    end
end

LoadSettings()

local IsAdmin, ExpiryTimestamp, AimbotActive = false, 0, false
local LastSync = 0
local CurrentKey = ""

local Players, LocalPlayer = game:GetService("Players"), game:GetService("Players").LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local HWID = game:GetService("RbxAnalyticsService"):GetClientId()

local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.Transparency = 1
FOVCircle.Color = Color3.new(1,1,1)
FOVCircle.Filled = false

local Colors = {
    MainBlue = Color3.fromRGB(0, 120, 255),
    AdminGold = Color3.fromRGB(255, 200, 0),
    BG = Color3.fromRGB(15, 15, 15),
    White = Color3.fromRGB(255, 255, 255),
    LogoutRed = Color3.fromRGB(200, 50, 50),
    Dark = Color3.fromRGB(25, 25, 25)
}

-- [[ СЕРВЕРНАЯ СИНХРОНИЗАЦИЯ ]] --
local function VerifyKey(key)
    local s, r = pcall(function() return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID) end)
    if s then
        CurrentKey = key
        if r == "admin" then 
            IsAdmin = true
            if canSave then writefile(KEY_FILE, key) end 
            return "ok"
        elseif r:find("valid") then
            ExpiryTimestamp = tonumber(string.split(r, "|")[2]) or 0
            IsAdmin = false
            if canSave then writefile(KEY_FILE, key) end 
            return "ok"
        end
    end
    return "invalid"
end

local function CreateToggle(parent, name, prop)
    local B = Instance.new("TextButton", parent)
    B.Size = UDim2.new(0.9, 0, 0, 35); B.Font = "GothamBold"; B.TextColor3 = Colors.White
    B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark
    B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 6)
    B.MouseButton1Click:Connect(function()
        Settings[prop] = not Settings[prop]
        B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
        B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark
        SaveSettings()
    end)
end

local function CreateSlider(parent, name, prop, min, max)
    local F = Instance.new("Frame", parent); F.Size = UDim2.new(0.9, 0, 0, 50); F.BackgroundTransparency = 1
    local L = Instance.new("TextLabel", F); L.Size = UDim2.new(1, 0, 0, 20); L.Text = name .. ": " .. Settings[prop]; L.TextColor3 = Colors.White; L.Font = "GothamBold"; L.BackgroundTransparency = 1
    local B = Instance.new("Frame", F); B.Size = UDim2.new(1, 0, 0, 5); B.Position = UDim2.new(0,0,0.7,0); B.BackgroundColor3 = Colors.Dark; Instance.new("UICorner", B)
    local Fill = Instance.new("Frame", B); Fill.Size = UDim2.new((Settings[prop]-min)/(max-min), 0, 1, 0); Fill.BackgroundColor3 = Colors.MainBlue; Instance.new("UICorner", Fill)
    local Btn = Instance.new("TextButton", B); Btn.Size = UDim2.new(1,0,1,0); Btn.BackgroundTransparency = 1; Btn.Text = ""
    local drag = false
    Btn.MouseButton1Down:Connect(function() drag = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false SaveSettings() end end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local p = math.clamp((i.Position.X - B.AbsolutePosition.X) / B.AbsoluteSize.X, 0, 1)
            Fill.Size = UDim2.new(p, 0, 1, 0)
            local v = math.round((min + (max-min)*p)*100)/100
            Settings[prop] = v; L.Text = name .. ": " .. v
        end
    end)
end

local MainFrame = nil
function BuildMenu()
    if CoreGui:FindFirstChild("IlliaV3_Menu") then CoreGui.IlliaV3_Menu:Destroy() end
    local G = Instance.new("ScreenGui", CoreGui); G.Name = "IlliaV3_Menu"
    
    MainFrame = Instance.new("ScrollingFrame", G)
    MainFrame.Size = UDim2.new(0, 280, 0, 400); MainFrame.Position = UDim2.new(0.5, -140, 0.5, -200)
    MainFrame.BackgroundColor3 = Colors.BG; MainFrame.AutomaticCanvasSize = "Y"; MainFrame.ScrollBarThickness = 0; MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame)
    
    local L = Instance.new("UIListLayout", MainFrame); L.Padding = UDim.new(0, 10); L.HorizontalAlignment = "Center"
    Instance.new("UIPadding", MainFrame).PaddingTop = UDim.new(0, 10)

    local H = Instance.new("TextLabel", MainFrame); H.Size = UDim2.new(1, 0, 0, 45); H.Font = "GothamBold"
    H.Text = IsAdmin and "👑 ILLIA V3 ADMIN" or "👤 ILLIA V3 USER"
    H.BackgroundColor3 = IsAdmin and Colors.AdminGold or Colors.MainBlue; H.TextColor3 = IsAdmin and Color3.new(0,0,0) or Colors.White; Instance.new("UICorner", H)

    local AimStatus = Instance.new("TextLabel", MainFrame); AimStatus.Size = UDim2.new(0.9, 0, 0, 30); AimStatus.Font = "GothamBold"; AimStatus.BackgroundTransparency = 1

    CreateSlider(MainFrame, "Радиус", "AimRadius", 50, 800)
    CreateSlider(MainFrame, "Плавность", "Sensitivity", 0.01, 1)
    CreateToggle(MainFrame, "FOV Круг", "ShowFOV")
    
    local EspSep = Instance.new("TextLabel", MainFrame); EspSep.Size = UDim2.new(0.9,0,0,20); EspSep.Text = "--- ESP ---"; EspSep.TextColor3 = Colors.MainBlue; EspSep.BackgroundTransparency = 1; EspSep.Font = "GothamBold"
    CreateToggle(MainFrame, "ESP Игроки", "ESP_Enabled")
    CreateToggle(MainFrame, "Радуга", "ESP_Rainbow")
    CreateSlider(MainFrame, "Цвет", "ESP_Hue", 0, 1)

    local Out = Instance.new("TextButton", MainFrame); Out.Size = UDim2.new(0.9, 0, 0, 35); Out.BackgroundColor3 = Colors.LogoutRed; Out.Text = "LOGOUT"; Out.TextColor3 = Colors.White; Out.Font = "GothamBold"; Instance.new("UICorner", Out)
    Out.MouseButton1Click:Connect(function() G:Destroy(); FOVCircle.Visible = false; if canSave then pcall(function() delfile(KEY_FILE) end) end; ShowLogin() end)

    RunService.RenderStepped:Connect(function()
        if G.Parent then
            local MousePos = UserInputService:GetMouseLocation()
            
            -- СИНХРОНИЗАЦИЯ С ТАБЛИЦЕЙ (РАЗ В 30 СЕКУНД)
            if not IsAdmin and tick() - LastSync > 30 then
                LastSync = tick()
                task.spawn(function()
                    local res = VerifyKey(CurrentKey)
                    if res == "invalid" or (ExpiryTimestamp > 0 and (ExpiryTimestamp/1000) < os.time()) then
                        G:Destroy()
                        FOVCircle.Visible = false
                        ShowLogin()
                    end
                end)
            end

            AimStatus.Text = "AIM ["..Settings.AimKey.."]: " .. (AimbotActive and "ACTIVE" or "OFF")
            AimStatus.TextColor3 = AimbotActive and Color3.new(0,1,0) or Color3.new(0.6,0.6,0.6)

            FOVCircle.Visible = Settings.ShowFOV
            FOVCircle.Radius = Settings.AimRadius
            FOVCircle.Position = MousePos 

            -- ESP
            if Settings.ESP_Enabled then
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        local h = p.Character:FindFirstChild("Highlight") or Instance.new("Highlight", p.Character)
                        h.Enabled = true
                        h.FillColor = Settings.ESP_Rainbow and Color3.fromHSV((tick()*0.5)%1, 0.8, 1) or Color3.fromHSV(Settings.ESP_Hue, 0.8, 1)
                    end
                end
            end

            -- AIMBOT (MOUSE CENTERED)
            if AimbotActive and Settings.AimbotEnabled then
                local target, dist = nil, Settings.AimRadius
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                        local p, vis = Camera:WorldToViewportPoint(v.Character.Head.Position)
                        if vis then
                            local mag = (Vector2.new(p.X, p.Y) - MousePos).Magnitude
                            if mag < dist then target = Vector2.new(p.X, p.Y); dist = mag end
                        end
                    end
                end
                if target then
                    local diff = (target - MousePos) * Settings.Sensitivity
                    mousemoverel(diff.X, diff.Y)
                end
            end
        end
    end)
end

function ShowLogin()
    if CoreGui:FindFirstChild("IlliaLogin") then CoreGui.IlliaLogin:Destroy() end
    local A = Instance.new("ScreenGui", CoreGui); A.Name = "IlliaLogin"
    local B = Instance.new("Frame", A); B.Size = UDim2.new(0, 300, 0, 200); B.Position = UDim2.new(0.5,-150,0.5,-100); B.BackgroundColor3 = Colors.BG; Instance.new("UICorner", B)
    local I = Instance.new("TextBox", B); I.Size = UDim2.new(0.8,0,0,40); I.Position = UDim2.new(0.1,0,0.25,0); I.PlaceholderText = "Ключ..."; I.BackgroundColor3 = Colors.Dark; I.TextColor3 = Colors.White; Instance.new("UICorner", I)
    local S = Instance.new("TextButton", B); S.Size = UDim2.new(0.8,0,0,40); S.Position = UDim2.new(0.1,0,0.6,0); S.BackgroundColor3 = Colors.MainBlue; S.Text = "ВОЙТИ"; S.TextColor3 = Colors.White; Instance.new("UICorner", S)
    S.MouseButton1Click:Connect(function()
        local res = VerifyKey(I.Text)
        if res == "ok" then A:Destroy(); BuildMenu() else I.Text = ""; I.PlaceholderText = "НЕВЕРНО" end
    end)
end

UserInputService.InputBegan:Connect(function(i, g)
    if i.KeyCode == Enum.KeyCode.Insert then
        if MainFrame then MainFrame.Visible = not MainFrame.Visible end
    elseif not g and i.KeyCode == Enum.KeyCode[Settings.AimKey] then
        AimbotActive = not AimbotActive
    end
end)

if canSave and isfile(KEY_FILE) then
    if VerifyKey(readfile(KEY_FILE)) == "ok" then BuildMenu() else ShowLogin() end
else ShowLogin() end
