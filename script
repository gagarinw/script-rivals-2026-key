end

-- [[ УПРАВЛЕНИЕ ]] --
UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Settings.MenuKey and ActiveMenu then
        ActiveMenu.Enabled = not ActiveMenu.Enabled
    elseif i.KeyCode == Settings.AimKey then
        AimbotActive = not AimbotActive
        if AimStatusLabel then
            AimStatusLabel.Text = "ЗАХВАТ [E]: " .. (AimbotActive and "ВКЛ" or "ВЫКЛ")
            AimStatusLabel.TextColor3 = AimbotActive and Color3.new(0,1,0) or Color3.new(1,0,0)
        end
    end
end)
