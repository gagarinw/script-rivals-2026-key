-- [[ ILLIA SYSTEM V3 - NEW COLORS & TOGGLE AIM ]] --

local API_URL = "https://script.google.com/macros/s/AKfycbyZuHTct49uHwi2Ukq3bClmQcbgSu_-y0ABZGn148EH1XbgFSTzF9MYzBxh8VKsIsMnnQ/exec"
local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local HWID = game:GetService("RbxAnalyticsService"):GetClientId()

local KEY_FILE = "illia_v3_key.txt"
local SETTINGS_FILE = "illia_v3_settings.json"
local canSave = (isfile and writefile and readfile)

-- [[ ЦВЕТОВАЯ ПАЛИТРА (ПО ТВОЕМУ ЗАПРОСУ) ]] --
local Colors = {
    MainBG = Color3.fromRGB(0, 0, 255),       -- Синий фон
    Button = Color3.fromRGB(128, 0, 128),     -- Фиолетовые кнопки
    DarkButton = Color3.fromRGB(0, 0, 139),   -- Темно-синие кнопки
    White = Color3.fromRGB(255, 255, 255)
}

local Settings = {
    AimbotEnabled = true,
    AimKey = "E",
    AimRadius = 150,
    Sensitivity = 0.25
}

local IsAdmin = false
local ExpiryTimestamp = 0
local AimbotToggled = false -- Режим вкл/выкл

-- [[ СОХРАНЕНИЕ ]] --
local function SaveSettings()
    if canSave then writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings)) end
end

local function LoadSettings()
    if canSave and isfile(SETTINGS_FILE) then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
        if ok then for k, v in pairs(data) do Settings[k] = v end end
    end
end

-- [[ АВТОРИЗАЦИЯ ]] --
local function VerifyKey(key)
    local ok, res = pcall(function() 
        return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID) 
    end)
    if ok then
        if res == "admin" then IsAdmin = true return "ok"
        elseif res:find("valid") then
            local p = string.split(res, "|")
            ExpiryTimestamp = tonumber(p[2]) or 0
            IsAdmin = false
            return "ok"
        end
    end
    return "Ошибка"
end

-- [[ ИНТЕРФЕЙС ]] --
local function BuildMenu()
    local Gui = Instance.new("ScreenGui", CoreGui)
    local Main = Instance.new("Frame", Gui)
    Main.Size = UDim2.new(0, 280, 0, 350); Main.Position = UDim2.new(0.5, -140, 0.5, -175)
    Main.BackgroundColor3 = Colors.MainBG; Instance.new("UICorner", Main)

    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 45); Title.Text = "ILLIA SYSTEM V3"
    Title.BackgroundColor3 = Colors.DarkButton; Title.TextColor3 = Colors.White
    Instance.new("UICorner", Title)

    -- Кнопка Аима (Фиолетовая)
    local AimBtn = Instance.new("TextButton", Main)
    AimBtn.Size = UDim2.new(0.9, 0, 0, 45); AimBtn.Position = UDim2.new(0.05, 0, 0.25, 0)
    AimBtn.BackgroundColor3 = Colors.Button
    AimBtn.TextColor3 = Colors.White
    
    task.spawn(function()
        while Gui.Parent do
            AimBtn.Text = "AIMBOT ["..Settings.AimKey.."]: "..(AimbotToggled and "ON" or "OFF")
            AimBtn.TextColor3 = AimbotToggled and Color3.new(0,1,0) or Colors.White
            task.wait(0.1)
        end
    end)

    -- Кнопка выхода (Темно-синяя)
    local ExitBtn = Instance.new("TextButton", Main)
    ExitBtn.Size = UDim2.new(0.9, 0, 0, 40); ExitBtn.Position = UDim2.new(0.05, 0, 0.8, 0)
    ExitBtn.BackgroundColor3 = Colors.DarkButton
    ExitBtn.Text = "LOGOUT"; ExitBtn.TextColor3 = Colors.White
    ExitBtn.MouseButton1Click:Connect(function()
        if canSave then pcall(function() delfile(KEY_FILE) end) end
        Gui:Destroy()
    end)
end

-- [[ ЛОГИКА АИМА ]] --
UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode.Name == Settings.AimKey then
        AimbotToggled = not AimbotToggled
    end
end)

