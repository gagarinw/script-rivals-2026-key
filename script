local function CleanResponse(text)
    if not text then return "" end
    return text:gsub("<[^>]*>", ""):gsub("%s+", "")
end

local function FormatTime(seconds)
    if seconds <= 0 then return "00:00:00" end
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", h, m, s)
end

local function VerifyKey(key)
    local url = API_URL .. "?check=" .. tostring(key) .. "&hwid=" .. HWID .. "&cb=" .. math.random(1, 99999)
    local s, r = pcall(function() return game:HttpGet(url) end)
    if s and r then
        local res = CleanResponse(r)
        if res == "admin" then 
            IsAdmin = true 
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif res:find("valid|") then
            local data = string.split(res, "|")
            if data[2] then
                ExpiryTimestamp = tonumber(data[2]) / 1000
                IsAdmin = false 
                if canSave then writefile(KEY_FILE, key) end
                return "ok"
            end
        end
    end
    return "invalid"
end

-- Логика ESP
local function UpdateESP()
    local espColor = Settings.ESP_Rainbow and Color3.fromHSV(tick() % 5 / 5, 1, 1) or Color3.fromHSV(Settings.ESP_Hue, 0.8, 1)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChild("IlliaESP")
            if Settings.ESP_Enabled then
                if not h then
                    h = Instance.new("Highlight", p.Character)
                    h.Name = "IlliaESP"
                end
                h.FillColor = espColor
                h.OutlineColor = Color3.new(1, 1, 1)
            else
                if h then h:Destroy() end
            end
        end
    end
end

-- UI Элементы (Слайдеры и кнопки как на скрине)
local function CreateToggle(parent, name, prop)
    local B = Instance.new("TextButton", parent)
    B.Size = UDim2.new(0.9, 0, 0, 45); B.Font = "GothamBold"; B.TextColor3 = Colors.White; B.TextSize = 14
    B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark; B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
    Instance.new("UICorner", B)
    B.MouseButton1Click:Connect(function()
        Settings[prop] = not Settings[prop]
        B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
        B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark
    end)
end

local function CreateSlider(parent, name, prop, min, max)
    local F = Instance.new("Frame", parent); F.Size = UDim2.new(0.9, 0, 0, 60); F.BackgroundTransparency = 1
    local L = Instance.new("TextLabel", F); L.Size = UDim2.new(1, 0, 0, 20); L.Text = name .. ": " .. Settings[prop]; L.TextColor3 = Colors.White; L.Font = "GothamBold"; L.BackgroundTransparency = 1
    local B = Instance.new("Frame", F); B.Size = UDim2.new(1, 0, 0, 6); B.Position = UDim2.new(0,0,0.7,0); B.BackgroundColor3 = Colors.Dark; Instance.new("UICorner", B)
    local Fill = Instance.new("Frame", B); Fill.Size = UDim2.new((Settings[prop]-min)/(max-min), 0, 1, 0); Fill.BackgroundColor3 = Colors.MainBlue; Instance.new("UICorner", Fill)
    local Btn = Instance.new("TextButton", B); Btn.Size = UDim2.new(1,0,1,0); Btn.BackgroundTransparency = 1; Btn.Text = ""
    local drag = false
    Btn.MouseButton1Down:Connect(function() drag = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local p = math.clamp((i.Position.X - B.AbsolutePosition.X) / B.AbsoluteSize.X, 0, 1)
            Fill.Size = UDim2.new(p, 0, 1, 0)
            local v = math.round((min + (max-min)*p)*10)/10
            Settings[prop] = v; L.Text = name .. ": " .. v
        end
    end)
end

function BuildMenu()
    if CoreGui:FindFirstChild("IlliaV3_Menu") then CoreGui.IlliaV3_Menu:Destroy() end
    local G = Instance.new("ScreenGui", CoreGui); G.Name = "IlliaV3_Menu"
    MainFrame = Instance.new("ScrollingFrame", G)
    MainFrame.Size = UDim2.new(0, 320, 0, 500); MainFrame.Position = UDim2.new(0.5, -160, 0.5, -250)
    MainFrame.BackgroundColor3 = Colors.BG; MainFrame.AutomaticCanvasSize = "Y"; MainFrame.ScrollBarThickness = 0; MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame)
    local L = Instance.new("UIListLayout", MainFrame); L.Padding = UDim.new(0, 10); L.HorizontalAlignment = "Center"
    Instance.new("UIPadding", MainFrame).PaddingTop = UDim.new(0, 15)

    CreateSlider(MainFrame, "Радиус", "AimRadius", 50, 800)
    CreateSlider(MainFrame, "Плавность", "Sensitivity", 0.01, 1)
    
    CreateToggle(MainFrame, "FOV Круг", "ShowFOV")
    CreateToggle(MainFrame, "ESP Игроки", "ESP_Enabled")
    
    -- Кнопки только для админа
    if IsAdmin then
        CreateToggle(MainFrame, "Радужный ESP", "ESP_Rainbow")
        CreateSlider(MainFrame, "Цвет ESP (Hue)", "ESP_Hue", 0, 1)
    end

    local Out = Instance.new("TextButton", MainFrame); Out.Size = UDim2.new(0.9, 0, 0, 45); Out.BackgroundColor3 = Colors.LogoutRed; Out.Text = "LOGOUT"; Out.TextColor3 = Colors.White; Out.Font = "GothamBold"; Instance.new("UICorner", Out)
    Out.MouseButton1Click:Connect(function() G:Destroy(); if canSave then pcall(function() delfile(KEY_FILE) end) end; ShowLogin() end)

    local Footer = Instance.new("TextLabel", MainFrame); Footer.Size = UDim2.new(1, 0, 0, 50); Footer.Font = "GothamBold"; Footer.TextSize = 16
    Footer.Text = IsAdmin and "👑 ILLIA V3 ADMIN" or "👤 ILLIA V3 USER"; Footer.BackgroundColor3 = Colors.MainBlue; Footer.TextColor3 = Colors.White; Instance.new("UICorner", Footer)
    
    local TimerLabel = Instance.new("TextLabel", MainFrame); TimerLabel.Size = UDim2.new(0.9, 0, 0, 30); TimerLabel.TextColor3 = Colors.White; TimerLabel.BackgroundTransparency = 1; TimerLabel.Font = "GothamBold"; TimerLabel.TextSize = 10

    RunService.RenderStepped:Connect(function()
        if G.Parent then
            local remaining = IsAdmin and 999999 or (ExpiryTimestamp - os.time())
            TimerLabel.Text = "ОСТАЛОСЬ: " .. FormatTime(remaining)
            FOVCircle.Visible = Settings.ShowFOV; FOVCircle.Radius = Settings.AimRadius; FOVCircle.Position = UserInputService:GetMouseLocation()
            UpdateESP()
            if not IsAdmin and remaining <= 0 then G:Destroy(); ShowLogin() end
        end
    end)
end

