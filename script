local function AddToggle(text, prop)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 38)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.TextColor3 = Color3.new(1, 1, 1)
    local function up()
        btn.Text = text .. ": " .. (Settings[prop] and "ON" or "OFF")
        btn.BackgroundColor3 = Settings[prop] and Colors.DarkBlue or Colors.Purple
    end
    btn.MouseButton1Click:Connect(function() Settings[prop] = not Settings[prop] up() end)
    up()
    Instance.new("UICorner", btn)
end

