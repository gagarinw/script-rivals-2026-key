}

LoadConfig()

-- [[ ПРОВЕРКА КЛЮЧА ]] --
local function VerifyKey(key)
    local success, result = pcall(function()
        return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID)
    end)
    if success then
        if result == "admin" or result == "valid" then
            writefile(KEY_FILE, key)
            IsAdmin = (result == "admin")
            return "ok"
        elseif result == "wrong_hwid" then return "Ключ занят другим ПК!"
        end
    end
    return "Неверный ключ!"
end

