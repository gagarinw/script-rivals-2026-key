-- [[ ILLIA SYSTEM V3 - FINAL RIVALS EDITION ]] --

local API_URL = "https://script.google.com/macros/s/AKfycbx3NDT8ZQ7LEHDjRBhUmNtEJ3IdYlK4CRpnlix2u_nrkwJoWLfNA1f7ZwUWwBzySTNWzg/exec"
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

local canSave = (isfile and readfile and writefile and delfile)
local KEY_FILE = "illia_v3_key.txt"
local SETTINGS_FILE = "illia_v3_settings.json"

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local HWID = game:GetService("RbxAnalyticsService"):GetClientId()

-- Дефолтные настройки
local Settings = {
    AimbotEnabled = true,
    AimRadius = 150,
    Sensitivity = 0.5,
    AimKey = Enum.KeyCode.E,
    ShowFOV = true,
    ESP_Enabled = true,
    ESP_Rainbow = false,
    ESP_Speed = 1,
    ESP_Hue = 0.6
}

local Colors = {
    MainBlue = Color3.fromRGB(0, 120, 255),
    BG = Color3.fromRGB(15, 15, 15),
    White = Color3.fromRGB(255, 255, 255),
    LogoutRed = Color3.fromRGB(200, 50, 50),
    Dark = Color3.fromRGB(25, 25, 25),
    AimOn = Color3.fromRGB(0, 255, 100)
}

local IsAdmin, ExpiryTimestamp = false, 0
local MenuVisible, AimActive = true, false
local MainFrame = nil

-- Система сохранения
local function SaveData()
    if canSave then
        pcall(function()
            writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings))
        end)
    end
end

local function LoadData()
    if canSave and isfile(SETTINGS_FILE) then
        local s, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
        if s then for i, v in pairs(data) do Settings[i] = v end end
    end
end
LoadData()

-- Рисование FOV
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.Transparency = 1
FOVCircle.Color = Colors.White
FOVCircle.Filled = false

local function FormatTime(seconds)
    if seconds <= 0 then return "00:00:00" end
    local h, m, s = math.floor(seconds / 3600), math.floor((seconds % 3600) / 60), math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", h, m, s)
end

-- Поиск головы (Fix для Rivals)
local function GetTargetPart(char)
    return char:FindFirstChild("Head") or char:FindFirstChild("FakeHead") or char:FindFirstChild("HumanoidRootPart")
end

local function GetClosestTarget()
    local closest, dist = nil, Settings.AimRadius
    local mouseLoc = UserInputService:GetMouseLocation()

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local part = GetTargetPart(p.Character)
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            
            if part and hum and hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mag = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                    if mag < dist then
                        closest = part
                        dist = mag
                    end
                end
            end
        end
    end
    return closest
end

-- Обновление ESP
local function UpdateESP()
    local espColor = Settings.ESP_Rainbow and Color3.fromHSV((tick() * (Settings.ESP_Speed * 0.2)) % 1, 0.8, 1) or Color3.fromHSV(Settings.ESP_Hue, 0.8, 1)
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChild("IlliaESP")
            if Settings.ESP_Enabled then
                if not h then
                    h = Instance.new("Highlight", p.Character)
                    h.Name = "IlliaESP"
                    h.OutlineTransparency = 0.1
                    h.FillTransparency = 0.5
                end
                h.FillColor = espColor
                h.OutlineColor = espColor
            elseif h then
                h:Destroy()
            end
        end
    end
end

-- Проверка ключа
local function VerifyKey(key)
    local url = API_URL .. "?check=" .. tostring(key) .. "&hwid=" .. HWID .. "&cb=" .. math.random(1, 99999)
    local s, r = pcall(function() return game:HttpGet(url) end)
    if s and r then
        local res = r:gsub("<[^>]*>", ""):gsub("%s+", "")
        if res == "admin" then IsAdmin = true return "ok"
        elseif res:find("valid|") then
            ExpiryTimestamp = tonumber(string.split(res, "|")[2]) / 1000
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        end
    end
    return "invalid"
end

-- Сборка Меню
function BuildMenu()
    if CoreGui:FindFirstChild("IlliaV3_Menu") then CoreGui.IlliaV3_Menu:Destroy() end
    local G = Instance.new("ScreenGui", CoreGui); G.Name = "IlliaV3_Menu"
    
    MainFrame = Instance.new("ScrollingFrame", G)
    MainFrame.Size = UDim2.new(0, 320, 0, 550); MainFrame.Position = UDim2.new(0.5, -160, 0.5, -275)
    MainFrame.BackgroundColor3 = Colors.BG; MainFrame.AutomaticCanvasSize = "Y"; MainFrame.ScrollBarThickness = 0; MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame)
    
    local L = Instance.new("UIListLayout", MainFrame); L.Padding = UDim.new(0, 10); L.HorizontalAlignment = "Center"
    Instance.new("UIPadding", MainFrame).PaddingTop = UDim.new(0, 15)

    local function CreateSlider(name, prop, min, max)
        local F = Instance.new("Frame", MainFrame); F.Size = UDim2.new(0.9, 0, 0, 60); F.BackgroundTransparency = 1
        local TL = Instance.new("TextLabel", F); TL.Size = UDim2.new(1, 0, 0, 20); TL.Text = name .. ": " .. Settings[prop]; TL.TextColor3 = Colors.White; TL.Font = "GothamBold"; TL.BackgroundTransparency = 1
        local B = Instance.new("Frame", F); B.Size = UDim2.new(1, 0, 0, 6); B.Position = UDim2.new(0,0,0.7,0); B.BackgroundColor3 = Colors.Dark; Instance.new("UICorner", B)
        local Fill = Instance.new("Frame", B); Fill.Size = UDim2.new((Settings[prop]-min)/(max-min), 0, 1, 0); Fill.BackgroundColor3 = Colors.MainBlue; Instance.new("UICorner", Fill)
        local Btn = Instance.new("TextButton", B); Btn.Size = UDim2.new(1,0,1,0); Btn.BackgroundTransparency = 1; Btn.Text = ""; local drag = false
        
        Btn.MouseButton1Down:Connect(function() drag = true end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false; SaveData() end end)
        UserInputService.InputChanged:Connect(function(i)
            if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                local p = math.clamp((i.Position.X - B.AbsolutePosition.X) / B.AbsoluteSize.X, 0, 1)
                Fill.Size = UDim2.new(p, 0, 1, 0)
                local v = math.round((min + (max-min)*p)*10)/10
                Settings[prop] = v; TL.Text = name .. ": " .. v
            end
        end)
    end

    local function CreateToggle(name, prop)
        local B = Instance.new("TextButton", MainFrame); B.Size = UDim2.new(0.9, 0, 0, 45); B.Font = "GothamBold"; B.TextColor3 = Colors.White; B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark; B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ"); Instance.new("UICorner", B)
        B.MouseButton1Click:Connect(function() Settings[prop] = not Settings[prop]; B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ"); B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark; SaveData() end)
    end

    CreateSlider("Радиус", "AimRadius", 50, 800)
    CreateSlider("Плавность", "Sensitivity", 0.1, 1)
    CreateToggle("FOV Круг", "ShowFOV")
    CreateToggle("ESP Игроки", "ESP_Enabled")
    CreateToggle("Радужный ESP", "ESP_Rainbow")
    CreateSlider("Скорость Радуги", "ESP_Speed", 0.1, 10)
    CreateSlider("Цвет ESP (Hue)", "ESP_Hue", 0, 1)

    local Out = Instance.new("TextButton", MainFrame); Out.Size = UDim2.new(0.9, 0, 0, 45); Out.BackgroundColor3 = Colors.LogoutRed; Out.Text = "LOGOUT"; Out.TextColor3 = Colors.White; Out.Font = "GothamBold"; Instance.new("UICorner", Out)
    Out.MouseButton1Click:Connect(function() G:Destroy(); AimActive = false; if canSave then pcall(function() delfile(KEY_FILE) end) end; ShowLogin() end)

    local Footer = Instance.new("TextLabel", MainFrame); Footer.Size = UDim2.new(1, 0, 0, 50); Footer.Font = "GothamBold"; Footer.Text = IsAdmin and "👑 ILLIA V3 ADMIN" or "👤 ILLIA V3 USER"; Footer.BackgroundColor3 = Colors.MainBlue; Footer.TextColor3 = Colors.White; Instance.new("UICorner", Footer)
    local TimerLabel = Instance.new("TextLabel", MainFrame); TimerLabel.Size = UDim2.new(0.9, 0, 0, 30); TimerLabel.TextColor3 = Colors.White; TimerLabel.BackgroundTransparency = 1; TimerLabel.Font = "GothamBold"; TimerLabel.TextSize = 12

    RunService.RenderStepped:Connect(function()
        local remaining = IsAdmin and 999999 or (ExpiryTimestamp - os.time())
        TimerLabel.Text = "ОСТАЛОСЬ: " .. FormatTime(remaining)
        
        FOVCircle.Visible = Settings.ShowFOV 
        FOVCircle.Radius = Settings.AimRadius
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Color = AimActive and Colors.AimOn or Colors.White
        
        UpdateESP()
        
        if AimActive and Settings.AimbotEnabled then
            local target = GetClosestTarget()
            if target then
                local lookAt = CFrame.new(Camera.CFrame.Position, target.Position)
                Camera.CFrame = Camera.CFrame:Lerp(lookAt, Settings.Sensitivity * 0.4)
            end
        end
    end)
end

function ShowLogin()
    local A = Instance.new("ScreenGui", CoreGui)
    local B = Instance.new("Frame", A); B.Size = UDim2.new(0, 320, 0, 180); B.Position = UDim2.new(0.5,-160,0.5,-90); B.BackgroundColor3 = Colors.BG; Instance.new("UICorner", B)
    local I = Instance.new("TextBox", B); I.Size = UDim2.new(0.8,0,0,45); I.Position = UDim2.new(0.1,0,0.2,0); I.PlaceholderText = "Введите ключ..."; I.BackgroundColor3 = Colors.Dark; I.TextColor3 = Colors.White; Instance.new("UICorner", I)
    local S = Instance.new("TextButton", B); S.Size = UDim2.new(0.8,0,0,45); S.Position = UDim2.new(0.1,0,0.6,0); S.BackgroundColor3 = Colors.MainBlue; S.Text = "ВОЙТИ"; S.TextColor3 = Colors.White; Instance.new("UICorner", S)
    
    -- Авто-вход
    if canSave and isfile(KEY_FILE) then
        local savedKey = readfile(KEY_FILE)
        if VerifyKey(savedKey) == "ok" then A:Destroy(); BuildMenu() return end
    end

    S.MouseButton1Click:Connect(function() 
        if VerifyKey(I.Text) == "ok" then A:Destroy(); BuildMenu() 
        else S.Text = "ОШИБКА"; task.wait(1); S.Text = "ВОЙТИ" end 
    end)
end

-- Ввод
UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.Insert then MenuVisible = not MenuVisible; if MainFrame then MainFrame.Visible = MenuVisible end end
    if i.KeyCode == Settings.AimKey then AimActive = true end
end)

UserInputService.InputEnded:Connect(function(i, g)
    if i.KeyCode == Settings.AimKey then AimActive = false end
end)

ShowLogin()
