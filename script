-- [[ ФУНКЦИЯ ТАЙМЕРА ]] --
local function GetTimeLeft()
    if IsAdmin then return "БЕССРОЧНО" end
    if ExpiryTimestamp == 0 then return "Загрузка..." end
    
    local expirySeconds = (ExpiryTimestamp > 2000000000000) and math.floor(ExpiryTimestamp / 1000) or ExpiryTimestamp
    local left = expirySeconds - os.time()
    
    if left <= 0 then return "ИСТЕК" end
    
    local m = math.floor((left % 3600) / 60)
    local s = math.floor(left % 60)
    return string.format("00ч %02dм %02dс", m, s)
end

-- [[ ПРОВЕРКА КЛЮЧА ]] --
local function VerifyKey(key)
    local success, result = pcall(function() 
        return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID) 
    end)

    if success then
        if result == "admin" then
            IsAdmin = true
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif result:find("valid") then
            local parts = string.split(result, "|")
            ExpiryTimestamp = tonumber(parts[2]) or 0
            IsAdmin = false
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif result == "expired" then return "Время ключа вышло!"
        elseif result == "wrong_hwid" then return "Ключ другого ПК!"
        end
    end
    return "Ошибка сервера!"
end

-- [[ ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ МЕНЮ ]] --
local function CreateSlider(parent, name, min, max, default, callback)
    local Frame = Instance.new("Frame", parent)
    Frame.Size = UDim2.new(0.9, 0, 0, 45); Frame.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, 0, 0, 20); Label.Text = name .. ": " .. default
    Label.TextColor3 = Colors.White; Label.BackgroundTransparency = 1; Label.Font = "GothamBold"

    local Bar = Instance.new("Frame", Frame)
    Bar.Size = UDim2.new(1, 0, 0, 6); Bar.Position = UDim2.new(0, 0, 0.6, 0)
    Bar.BackgroundColor3 = Color3.fromRGB(40, 40, 40); Instance.new("UICorner", Bar)

    local Fill = Instance.new("Frame", Bar)
    Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    Fill.BackgroundColor3 = Colors.MainBlue; Instance.new("UICorner", Fill)

    local Trigger = Instance.new("TextButton", Bar)
    Trigger.Size = UDim2.new(1, 0, 1, 0); Trigger.BackgroundTransparency = 1; Trigger.Text = ""

    local dragging = false
    Trigger.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local per = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
            Fill.Size = UDim2.new(per, 0, 1, 0)
            local val = math.round((min + (max - min) * per) * 100) / 100
            Label.Text = name .. ": " .. val
            callback(val)
        end
    end)
end

-- [[ ГЛАВНОЕ МЕНЮ (USER & ADMIN) ]] --
function BuildMenu()
    if CoreGui:FindFirstChild("IlliaV3_Menu") then CoreGui.IlliaV3_Menu:Destroy() end
    
    local Gui = Instance.new("ScreenGui", CoreGui); Gui.Name = "IlliaV3_Menu"
    local Main = Instance.new("ScrollingFrame", Gui)
    Main.Size = UDim2.new(0, 280, 0, 420); Main.Position = UDim2.new(0.5, -140, 0.5, -210)
    Main.BackgroundColor3 = Colors.BG; Main.BorderSizePixel = 0; Main.ScrollBarThickness = 2
    Instance.new("UICorner", Main)

    local List = Instance.new("UIListLayout", Main); List.Padding = UDim.new(0, 12); List.HorizontalAlignment = "Center"

    -- Шапка (Цвет меняется в зависимости от прав)
    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 0, 50); Header.Font = "GothamBold"; Header.TextSize = 16
    Header.Text = IsAdmin and "👑 ADMIN PANEL" or "👤 USER PANEL"
    Header.BackgroundColor3 = IsAdmin and Colors.AdminGold or Colors.MainBlue
    Header.TextColor3 = IsAdmin and Color3.new(0,0,0) or Colors.White
    Instance.new("UICorner", Header)

    -- Таймер (Работает для всех)
    local TimerLabel = Instance.new("TextLabel", Main)
    TimerLabel.Size = UDim2.new(0.9, 0, 0, 25); TimerLabel.BackgroundTransparency = 1
    TimerLabel.TextColor3 = Colors.White; TimerLabel.Font = "GothamBold"

    -- Кнопка Аима
    local AimBtn = Instance.new("TextButton", Main)
    AimBtn.Size = UDim2.new(0.9, 0, 0, 40); AimBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    AimBtn.TextColor3 = Colors.White; AimBtn.Font = "GothamBold"; Instance.new("UICorner", AimBtn)

    -- Слайдеры
    CreateSlider(Main, "Радиус", 50, 500, Settings.AimRadius, function(v) Settings.AimRadius = v end)
    CreateSlider(Main, "Плавность", 0.05, 1, Settings.Sensitivity, function(v) Settings.Sensitivity = v end)

    -- Кнопка выхода
    local Logout = Instance.new("TextButton", Main)
    Logout.Size = UDim2.new(0.9, 0, 0, 40); Logout.BackgroundColor3 = Colors.LogoutRed
    Logout.Text = "ВЫЙТИ (LOGOUT)"; Logout.TextColor3 = Colors.White; Instance.new("UICorner", Logout)

    Logout.MouseButton1Click:Connect(function()
        if canSave then pcall(function() delfile(KEY_FILE) end) end
        Gui:Destroy(); FOVCircle.Visible = false; ShowLogin()
    end)

    -- ОБНОВЛЕНИЕ СОСТОЯНИЙ
    RunService.RenderStepped:Connect(function()
        if Gui.Parent then
            TimerLabel.Text = "До конца: " .. GetTimeLeft()
            AimBtn.Text = "ЗАХВАТ [E]: " .. (AimbotActive and "ВКЛ" or "ВЫКЛ")
            AimBtn.TextColor3 = AimbotActive and Color3.new(0,1,0) or Color3.new(1,0,0)
            
            FOVCircle.Visible = Settings.ShowFOV
            FOVCircle.Radius = Settings.AimRadius
            FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            
            if AimbotActive then
                local target = nil
                local dist = Settings.AimRadius
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
                        local pos, vis = Camera:WorldToViewportPoint(p.Character.Head.Position)
                        if vis then
                            local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                            if mag < dist then target = p.Character.Head; dist = mag end
                        end
                    end
                end
                if target then
                    local p = Camera:WorldToViewportPoint(target.Position)
                    mousemoverel((p.X - Camera.ViewportSize.X/2) * Settings.Sensitivity, (p.Y - Camera.ViewportSize.Y/2) * Settings.Sensitivity)
                end
            end
        end
    end)
end

