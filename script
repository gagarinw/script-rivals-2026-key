}

local function FormatTime(seconds)
    if seconds <= 0 then return "ИСТЕК" end
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", h, m, s)
end

-- ИСПРАВЛЕННАЯ ФУНКЦИЯ ПРОВЕРКИ
local function VerifyKey(key)
    local s, r = pcall(function() return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID) end)
    if s and r ~= "invalid" then
        CurrentKey = key
        if r == "admin" then 
            IsAdmin = true 
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif r:find("valid") then
            local data = string.split(r, "|")
            -- Получаем время из Google (миллисекунды) и переводим в секунды Lua
            ExpiryTimestamp = tonumber(data[2]) / 1000
            IsAdmin = false 
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        end
    end
    return "invalid"
end

local MainFrame = nil
local function ToggleMenu()
    if not MainFrame then return end
    MenuVisible = not MenuVisible
    local targetSize = MenuVisible and UDim2.new(0, 320, 0, 500) or UDim2.new(0, 320, 0, 0)
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    TweenService:Create(MainFrame, tweenInfo, {Size = targetSize}):Play()
    for _, item in pairs(MainFrame:GetChildren()) do
        if item:IsA("GuiObject") then item.Visible = MenuVisible end
    end
end

function BuildMenu()
    if CoreGui:FindFirstChild("IlliaV3_Menu") then CoreGui.IlliaV3_Menu:Destroy() end
    local G = Instance.new("ScreenGui", CoreGui); G.Name = "IlliaV3_Menu"
    
    MainFrame = Instance.new("ScrollingFrame", G)
    MainFrame.Size = UDim2.new(0, 320, 0, 500); MainFrame.Position = UDim2.new(0.5, -160, 0.5, -250)
    MainFrame.BackgroundColor3 = Colors.BG; MainFrame.AutomaticCanvasSize = "Y"; MainFrame.ScrollBarThickness = 0; MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame)
    
    local L = Instance.new("UIListLayout", MainFrame); L.Padding = UDim.new(0, 12); L.HorizontalAlignment = "Center"
    Instance.new("UIPadding", MainFrame).PaddingTop = UDim.new(0, 15)

    local H = Instance.new("TextLabel", MainFrame); H.Size = UDim2.new(1, 0, 0, 55); H.Font = "GothamBold"; H.TextSize = 20
    H.Text = IsAdmin and "👑 ILLIA V3 ADMIN" or "👤 ILLIA V3 USER"
    H.BackgroundColor3 = IsAdmin and Colors.AdminGold or Colors.MainBlue; H.TextColor3 = IsAdmin and Color3.new(0,0,0) or Colors.White; Instance.new("UICorner", H)

    local TimerLabel = Instance.new("TextLabel", MainFrame); TimerLabel.Size = UDim2.new(0.9, 0, 0, 30); TimerLabel.TextColor3 = Colors.White; TimerLabel.BackgroundTransparency = 1; TimerLabel.Font = "GothamBold"; TimerLabel.TextSize = 16

    -- Кнопка выхода
    local Out = Instance.new("TextButton", MainFrame); Out.Size = UDim2.new(0.9, 0, 0, 40); Out.BackgroundColor3 = Colors.LogoutRed; Out.Text = "LOGOUT"; Out.TextColor3 = Colors.White; Out.Font = "GothamBold"; Out.TextSize = 16; Instance.new("UICorner", Out)
    Out.MouseButton1Click:Connect(function() G:Destroy(); FOVCircle.Visible = false; if canSave then pcall(function() delfile(KEY_FILE) end) end; ShowLogin() end)

    -- ЦИКЛ ОБНОВЛЕНИЯ ТАЙМЕРА И ESP
    RunService.RenderStepped:Connect(function()
        if G.Parent then
            local MousePos = UserInputService:GetMouseLocation()
            
            -- ИСПРАВЛЕННЫЙ РАСЧЕТ ОСТАВШЕГОСЯ ВРЕМЕНИ
            if IsAdmin then
                TimerLabel.Text = "СТАТУС: БЕССРОЧНО"
            else
                local remaining = ExpiryTimestamp - os.time()
                TimerLabel.Text = "ОСТАЛОСЬ: " .. FormatTime(remaining)
                
                -- Авто-выход если время вышло
                if remaining <= 0 then
                    G:Destroy(); ShowLogin()
                end
            end

            FOVCircle.Visible = Settings.ShowFOV; FOVCircle.Radius = Settings.AimRadius; FOVCircle.Position = MousePos 
        end
    end)
end

function ShowLogin()
    if CoreGui:FindFirstChild("IlliaLogin") then CoreGui.IlliaLogin:Destroy() end
    local A = Instance.new("ScreenGui", CoreGui); A.Name = "IlliaLogin"
    local B = Instance.new("Frame", A); B.Size = UDim2.new(0, 340, 0, 240); B.Position = UDim2.new(0.5,-170,0.5,-120); B.BackgroundColor3 = Colors.BG; Instance.new("UICorner", B)
    local I = Instance.new("TextBox", B); I.Size = UDim2.new(0.8,0,0,50); I.Position = UDim2.new(0.1,0,0.2,0); I.PlaceholderText = "Ключ..."; I.BackgroundColor3 = Colors.Dark; I.TextColor3 = Colors.White; I.TextSize = 18; Instance.new("UICorner", I)
    local S = Instance.new("TextButton", B); S.Size = UDim2.new(0.8,0,0,50); S.Position = UDim2.new(0.1,0,0.6,0); S.BackgroundColor3 = Colors.MainBlue; S.Text = "ВОЙТИ"; S.TextColor3 = Colors.White; S.TextSize = 18; Instance.new("UICorner", S)
    
    local busy = false
    S.MouseButton1Click:Connect(function()
        if busy then return end
        busy = true
        S.Text = "ПРОВЕРКА..."
        task.spawn(function()
            local res = VerifyKey(I.Text)
            if res == "ok" then
                S.Text = "УСПЕШНО!"
                S.BackgroundColor3 = Colors.SuccessGreen
                task.wait(0.5); A:Destroy(); BuildMenu()
            else
                S.Text = "НЕВЕРНЫЙ КЛЮЧ"
                S.BackgroundColor3 = Colors.LogoutRed
                task.wait(1.5); S.Text = "ВОЙТИ"; S.BackgroundColor3 = Colors.MainBlue; busy = false
            end
        end)
    end)
end

UserInputService.InputBegan:Connect(function(i, g)
