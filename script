local API_URL = "https://script.google.com/macros/s/AKfycbyeA-rWBrLS6otVeDtjQvSf3Dfu_0OhX3BHFdq-4M42OYz6aDUy71BO7gARj-fsySztgQ/exec"
local GEN_LINK = API_URL 
local HttpService = game:GetService("HttpService")

-- Файлы для сохранения
local KEY_FILE = "illia_v3_key.txt"
local SETTINGS_FILE = "illia_v3_settings.json"

local Settings = {
    AimbotEnabled = true,
    ESP_Enabled = true,
    ESP_Rainbow = false, 
    ESP_Hue = 0.6,       
    ShowFOV = false,     
    AimRadius = 150,     
    Sensitivity = 0.25, 
    MenuKey = Enum.KeyCode.Insert,
    AimKey = Enum.KeyCode.E        
}

-- Функция сохранения настроек
local function SaveConfig()
    writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings))
end

-- Функция загрузки настроек
local function LoadConfig()
    if isfile(SETTINGS_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
        if success then
            for k, v in pairs(data) do Settings[k] = v end
        end
    end
end

