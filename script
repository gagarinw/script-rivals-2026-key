local API_URL = "https://script.google.com/macros/s/AKfycbx3NDT8ZQ7LEHDjRBhUmNtEJ3IdYlK4CRpnlix2u_nrkwJoWLfNA1f7ZwUWwBzySTNWzg/exec"
local HttpService = game:GetService("HttpService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local HWID = game:GetService("RbxAnalyticsService"):GetClientId()

-- Проверка поддержки движения мыши (для аима)
local movemouse = mousemoverel or (Input and (Input.mousemove or Input.movemouse))

-- Файлы сохранения
local canSave = (writefile and readfile and isfile)
local KEY_FILE = "illia_v3_key.txt"
local SETTINGS_FILE = "illia_v3_settings.json"

-- Настройки (твои параметры)
local Settings = {
    AimbotEnabled = true,
    TeamCheck = true, 
    ESP_Enabled = true,
    ESP_Rainbow = false,
    ESP_Hue = 0.6,
    ESP_Speed = 1,
    ShowFOV = true,
    AimRadius = 150,
    Sensitivity = 0.3, 
    AimPart = "Head", -- В Rivals также может быть "UpperTorso"
    MenuKey = Enum.KeyCode.Insert,
    AimKey = Enum.KeyCode.E -- Кнопка активации аима
}

local Colors = {
    MainBlue = Color3.fromRGB(0, 100, 255),
    DarkBlue = Color3.fromRGB(0, 35, 100),
    Purple = Color3.fromRGB(120, 40, 180),
    Background = Color3.fromRGB(15, 15, 15),
    TitleBar = Color3.fromRGB(25, 25, 25)
}

local IsAdmin, ExpiryTimestamp = false, 0
local AimActive = false
local MainFrame = nil

-- Загрузка настроек
if canSave and isfile(SETTINGS_FILE) then
    pcall(function()
        local data = HttpService:JSONDecode(readfile(SETTINGS_FILE))
        for i, v in pairs(data) do Settings[i] = v end
    end)
end

-- FOV КРУГ
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.Visible = false
FOVCircle.Transparency = 1
FOVCircle.Filled = false

-- Функция проверки врага
local function IsEnemy(p)
    if not Settings.TeamCheck then return true end
    return p.Team ~= LocalPlayer.Team
end

-- [[ ПРОВЕРКА КЛЮЧА ]] --
local function VerifyKey(key)
    local url = API_URL .. "?check=" .. tostring(key) .. "&hwid=" .. HWID .. "&cb=" .. math.random(1, 99999)
    local s, r = pcall(function() return game:HttpGet(url) end)
    if s and r then
        local res = r:gsub("<[^>]*>", ""):gsub("%s+", "")
        if res == "admin" then 
            IsAdmin = true 
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif res:find("valid|") then
            ExpiryTimestamp = tonumber(string.split(res, "|")[2]) / 1000
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        end
    end
    return "invalid"
end

-- [[ ПОИСК ЦЕЛИ (ТВОЯ ЛОГИКА) ]] --
local function GetClosestTarget()
    local targetPos = nil
    local dist = Settings.AimRadius
    local mouseLoc = UserInputService:GetMouseLocation()

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local char = p.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            -- Поиск части тела (поддержка Rivals Hitbox)
            local part = char:FindFirstChild(Settings.AimPart) or (char:FindFirstChild("Hitbox") and char.Hitbox:FindFirstChild(Settings.AimPart))

            if part and hum and hum.Health > 0 and IsEnemy(p) then
                local pos, vis = Camera:WorldToViewportPoint(part.Position)
                if vis then
                    local mDist = (Vector2.new(pos.X, pos.Y) - mouseLoc).Magnitude
                    if mDist < dist then
                        dist = mDist
                        targetPos = Vector2.new(pos.X, pos.Y)
                    end
                end
            end
        end
    end
    return targetPos
end

-- [[ ОБНОВЛЕНИЕ ESP ]] --
local function UpdateESP()
    local espColor = Settings.ESP_Rainbow and Color3.fromHSV((tick() * (Settings.ESP_Speed * 0.2)) % 1, 0.8, 1) or Color3.fromHSV(Settings.ESP_Hue, 0.8, 1)
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local highlight = p.Character:FindFirstChild("ILLIA_CHAMS")
            if Settings.ESP_Enabled and IsEnemy(p) then
                if not highlight then
                    highlight = Instance.new("Highlight", p.Character)
                    highlight.Name = "ILLIA_CHAMS"
                    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                end
                highlight.FillColor = espColor
                highlight.OutlineColor = Color3.new(1,1,1)
            elseif highlight then
                highlight:Destroy()
            end
        end
    end
end

-- [[ ГЛАВНЫЙ ЦИКЛ ]] --
RunService.RenderStepped:Connect(function()
    FOVCircle.Position = UserInputService:GetMouseLocation()
    FOVCircle.Radius = Settings.AimRadius
    FOVCircle.Visible = Settings.ShowFOV
    FOVCircle.Color = AimActive and Colors.MainBlue or Color3.new(1, 1, 1)

    UpdateESP()

    if AimActive and Settings.AimbotEnabled and movemouse then
        local target = GetClosestTarget()
        if target then
            local mouseLoc = UserInputService:GetMouseLocation()
            local diff = (target - mouseLoc) * Settings.Sensitivity
            movemouse(diff.X, diff.Y)
        end
    end
end)

-- [[ МЕНЮ ]] --
function BuildMenu()
    if CoreGui:FindFirstChild("IlliaMenuV3") then CoreGui.IlliaMenuV3:Destroy() end
    local MainGui = Instance.new("ScreenGui", CoreGui); MainGui.Name = "IlliaMenuV3"
    
    MainFrame = Instance.new("Frame", MainGui)
    MainFrame.BackgroundColor3 = Colors.Background
    MainFrame.Size = UDim2.new(0, 280, 0, 520)
    MainFrame.Position = UDim2.new(0.5, -140, 0.5, -260)
    Instance.new("UICorner", MainFrame)

    local Title = Instance.new("TextLabel", MainFrame)
    Title.Size = UDim2.new(1, 0, 0, 50); Title.Text = "ILLIA V3"; Title.TextColor3 = Color3.new(1, 1, 1)
    Title.BackgroundColor3 = Colors.TitleBar; Title.Font = "GothamBold"; Title.TextSize = 24
    Instance.new("UICorner", Title)

    local UIList = Instance.new("UIListLayout", MainFrame); UIList.Padding = UDim.new(0, 8); UIList.HorizontalAlignment = "Center"
    Instance.new("UIPadding", MainFrame).PaddingTop = UDim.new(0, 60)

    local function CreateButton(text, prop)
        local btn = Instance.new("TextButton", MainFrame)
        btn.Size = UDim2.new(0.9, 0, 0, 35); btn.Font = "GothamBold"; btn.TextColor3 = Color3.new(1, 1, 1)
        local function upd() 
            btn.Text = text .. ": " .. (Settings[prop] and "ON" or "OFF")
            btn.BackgroundColor3 = Settings[prop] and Colors.DarkBlue or Colors.Purple
        end
        btn.MouseButton1Click:Connect(function() Settings[prop] = not Settings[prop]; upd(); if canSave then writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings)) end end)
        upd(); Instance.new("UICorner", btn)
    end

    local function CreateSlider(text, prop, min, max)
        local f = Instance.new("Frame", MainFrame); f.Size = UDim2.new(0.9, 0, 0, 45); f.BackgroundTransparency = 1
        local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1, 0, 0, 20); l.TextColor3 = Color3.new(1, 1, 1); l.TextSize = 12; l.Font = "GothamBold"; l.BackgroundTransparency = 1
        local b = Instance.new("Frame", f); b.Size = UDim2.new(1, 0, 0, 5); b.Position = UDim2.new(0, 0, 0, 30); b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        local fill = Instance.new("Frame", b); fill.BackgroundColor3 = Colors.MainBlue
        local k = Instance.new("TextButton", b); k.Size = UDim2.new(0, 12, 0, 12); k.Text = ""
        Instance.new("UICorner", b); Instance.new("UICorner", fill); Instance.new("UICorner", k)
        
        local function upd(val)
            local p = (val - min) / (max - min)
            fill.Size = UDim2.new(p, 0, 1, 0); k.Position = UDim2.new(p, -6, 0.5, -6)
            l.Text = text .. ": " .. tostring(val)
        end
        local drag = false
        k.MouseButton1Down:Connect(function() drag = true end)
        UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false; if canSave then writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings)) end end end)
        UserInputService.InputChanged:Connect(function(i)
            if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
                local p = math.clamp((i.Position.X - b.AbsolutePosition.X) / b.AbsoluteSize.X, 0, 1)
                local v = max <= 1 and math.round((min + (max - min) * p) * 100) / 100 or math.floor(min + (max - min) * p)
                Settings[prop] = v; upd(v)
            end
        end)
        upd(Settings[prop])
    end

    CreateButton("Team Check", "TeamCheck")
    CreateButton("ESP Master", "ESP_Enabled")
    CreateButton("ESP Rainbow", "ESP_Rainbow")
    CreateSlider("ESP Hue", "ESP_Hue", 0, 1)
    CreateSlider("ESP Speed", "ESP_Speed", 1, 10)
    CreateButton("Show FOV", "ShowFOV")
    CreateSlider("FOV Radius", "AimRadius", 50, 500)
    CreateSlider("Aim Speed", "Sensitivity", 0.05, 1)
end

