-- [[ ЛОГИКА ESP ]] --
local function ApplyESP(player)
    local function CreateHighlight()
        if not player.Character then return end
        local char = player.Character
        local h = char:FindFirstChild("ILLIA_CHAMS") or Instance.new("Highlight")
        h.Name = "ILLIA_CHAMS"
        h.Parent = char
        h.Adornee = char
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.FillAlpha = 0.5
        h.OutlineAlpha = 0
        return h
    end

    RunService.RenderStepped:Connect(function()
        if player.Character and Settings.ESP_Enabled and MainGui.Enabled then
            local h = player.Character:FindFirstChild("ILLIA_CHAMS") or CreateHighlight()
            if h then
                h.Enabled = true
                local color = Settings.ESP_Rainbow and Color3.fromHSV((tick() * 0.5) % 1, 0.8, 1) or Color3.fromHSV(Settings.ESP_Hue, 0.8, 1)
                h.FillColor = color
                h.OutlineColor = color
            end
        else
            if player.Character and player.Character:FindFirstChild("ILLIA_CHAMS") then
                player.Character.ILLIA_CHAMS.Enabled = false
            end
        end
    end)
end

for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then ApplyESP(p) end end
Players.PlayerAdded:Connect(function(p) if p ~= LocalPlayer then ApplyESP(p) end end)

