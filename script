local function FormatTime(seconds)
    if seconds <= 0 then return "00:00:00" end
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", h, m, s)
end

-- ИСПРАВЛЕННАЯ ФУНКЦИЯ ПРОВЕРКИ (Убрана причина вечной "ОШИБКИ")
local function VerifyKey(key)
    -- Глубокая очистка ключа и добавление анти-кэша
    local cleanKey = tostring(key):gsub("%s+", "")
    local url = API_URL .. "?check=" .. cleanKey .. "&hwid=" .. HWID .. "&cb=" .. math.random(1, 99999)
    
    local s, r = pcall(function() return game:HttpGet(url) end)
    
    if s and r then
        -- Убираем из ответа любой мусор, который может слать Google
        local cleanResponse = r:gsub("<[^>]*>", ""):gsub("%s+", "")
        
        if cleanResponse == "admin" then 
            IsAdmin = true 
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif cleanResponse:find("valid|") then
            local data = string.split(cleanResponse, "|")
            if data[2] and tonumber(data[2]) then
                ExpiryTimestamp = tonumber(data[2]) / 1000
                IsAdmin = false 
                if canSave then writefile(KEY_FILE, key) end
                return "ok"
            end
        end
    end
    return "invalid"
end

local function ToggleMenu()
    if not MainFrame then return end
    MenuVisible = not MenuVisible
    local targetSize = MenuVisible and UDim2.new(0, 320, 0, 500) or UDim2.new(0, 320, 0, 0)
    TweenService:Create(MainFrame, TweenInfo.new(0.3), {Size = targetSize}):Play()
    for _, item in pairs(MainFrame:GetChildren()) do
        if item:IsA("GuiObject") then item.Visible = MenuVisible end
    end
end

local function CreateToggle(parent, name, prop)
    local B = Instance.new("TextButton", parent)
    B.Size = UDim2.new(0.9, 0, 0, 45); B.Font = "GothamBold"; B.TextColor3 = Colors.White; B.TextSize = 14
    B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark
    B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 8)
    B.MouseButton1Click:Connect(function()
        Settings[prop] = not Settings[prop]
        B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
        B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark
        SaveSettings()
    end)
end

local function CreateSlider(parent, name, prop, min, max)
    local F = Instance.new("Frame", parent); F.Size = UDim2.new(0.9, 0, 0, 60); F.BackgroundTransparency = 1
    local L = Instance.new("TextLabel", F); L.Size = UDim2.new(1, 0, 0, 20); L.Text = name .. ": " .. Settings[prop]; L.TextColor3 = Colors.White; L.Font = "GothamBold"; L.BackgroundTransparency = 1
    local B = Instance.new("Frame", F); B.Size = UDim2.new(1, 0, 0, 6); B.Position = UDim2.new(0,0,0.7,0); B.BackgroundColor3 = Colors.Dark; Instance.new("UICorner", B)
    local Fill = Instance.new("Frame", B); Fill.Size = UDim2.new((Settings[prop]-min)/(max-min), 0, 1, 0); Fill.BackgroundColor3 = Colors.MainBlue; Instance.new("UICorner", Fill)
    local Btn = Instance.new("TextButton", B); Btn.Size = UDim2.new(1,0,1,0); Btn.BackgroundTransparency = 1; Btn.Text = ""
    local drag = false
    Btn.MouseButton1Down:Connect(function() drag = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false SaveSettings() end end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local p = math.clamp((i.Position.X - B.AbsolutePosition.X) / B.AbsoluteSize.X, 0, 1)
            Fill.Size = UDim2.new(p, 0, 1, 0)
            local v = math.round((min + (max-min)*p)*10)/10
            Settings[prop] = v; L.Text = name .. ": " .. v
        end
    end)
end

