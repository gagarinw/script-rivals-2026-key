    local Inp = Instance.new("TextBox", Box)
    Inp.Size = UDim2.new(0.8, 0, 0, 40)
    Inp.Position = UDim2.new(0.1, 0, 0.25, 0)
    Inp.PlaceholderText = "Введите новый ключ..."
    Inp.BackgroundColor3 = Color3.fromRGB(30,30,30)
