end

-- ПРОВЕРКА ПРИ ЗАПУСКЕ
if isfile(KEY_FILE) then
    local savedKey = readfile(KEY_FILE)
    local r = VerifyKey(savedKey)
    if r == "ok" then StartCheat() else ShowLogin() end
else
