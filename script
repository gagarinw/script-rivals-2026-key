local function CreateButton(text, prop, tOn, tOff)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 16
    btn.TextColor3 = Color3.new(1, 1, 1)
    local function update()
        btn.Text = text .. ": " .. (Settings[prop] and (tOn or "ON") or (tOff or "OFF"))
        btn.BackgroundColor3 = Settings[prop] and Colors.DarkBlue or Colors.Purple
    end
    btn.MouseButton1Click:Connect(function() Settings[prop] = not Settings[prop] update() end)
    update()
    Instance.new("UICorner", btn)
end

local function CreateSlider(text, prop, min, max)
    local f = Instance.new("Frame", MainFrame)
    f.Size = UDim2.new(0.9, 0, 0, 45)
    f.BackgroundTransparency = 1
    local l = Instance.new("TextLabel", f)
    l.Size = UDim2.new(1, 0, 0, 15)
    l.TextColor3 = Color3.new(1, 1, 1)
    l.TextSize = 12
    l.Font = Enum.Font.GothamBold
    l.BackgroundTransparency = 1
    l.TextXAlignment = Enum.TextXAlignment.Left
    local b = Instance.new("Frame", f)
    b.Size = UDim2.new(1, 0, 0, 5)
    b.Position = UDim2.new(0, 0, 0, 25)
    b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    local fill = Instance.new("Frame", b)
    fill.BackgroundColor3 = Colors.MainBlue
    local k = Instance.new("TextButton", b)
    k.Size = UDim2.new(0, 14, 0, 14)
    k.Text = ""
    Instance.new("UICorner", b) Instance.new("UICorner", fill) Instance.new("UICorner", k)
    local function up(val)
        local p = (val - min) / (max - min)
        fill.Size = UDim2.new(p, 0, 1, 0)
        k.Position = UDim2.new(p, -7, 0.5, -7)
        l.Text = text .. ": " .. tostring(val)
    end
    local drag = false
    k.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    UserInputService.InputChanged:Connect(function(i)
        if drag and i.UserInputType == Enum.UserInputType.MouseMovement then
            local p = math.clamp((i.Position.X - b.AbsolutePosition.X) / b.AbsoluteSize.X, 0, 1)
            local v = max <= 1 and math.round((min + (max - min) * p) * 100) / 100 or math.floor(min + (max - min) * p)
            Settings[prop] = v
            up(v)
        end
    end)
    up(Settings[prop])
end

