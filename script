-- [[ ILLIA SYSTEM V3 - ORIGINAL COLORS & FIX ]] --

local API_URL = "https://script.google.com/macros/s/AKfycbx3NDT8ZQ7LEHDjRBhUmNtEJ3IdYlK4CRpnlix2u_nrkwJoWLfNA1f7ZwUWwBzySTNWzg/exec"
local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

local canSave = (isfile and readfile and writefile and delfile)
local KEY_FILE = "illia_v3_key.txt"
local SETTINGS_FILE = "illia_v3_settings.json"

local LocalPlayer = Players.LocalPlayer
local HWID = game:GetService("RbxAnalyticsService"):GetClientId()

-- Настройки
local Settings = {
    AimbotEnabled = true,
    AimRadius = 150,
    Sensitivity = 0.2, 
    AimKey = "T",
    ShowFOV = true,
    ESP_Enabled = true,
    ESP_Hue = 0.6
}

-- ВОЗВРАЩЕННЫЕ ЦВЕТА ИЗ ТВОЕГО СКРИПТА
local Colors = {
    MainBlue = Color3.fromRGB(0, 120, 255), -- Тот самый синий
    AdminGold = Color3.fromRGB(255, 200, 0),
    BG = Color3.fromRGB(15, 15, 15),
    White = Color3.fromRGB(255, 255, 255),
    LogoutRed = Color3.fromRGB(200, 50, 50),
    SuccessGreen = Color3.fromRGB(40, 200, 40),
    Dark = Color3.fromRGB(25, 25, 25)
}

local function SaveSettings()
    if canSave then writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings)) end
end

local function LoadSettings()
    if canSave and isfile(SETTINGS_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
        if success then for k, v in pairs(data) do Settings[k] = v end end
    end
end

LoadSettings()

local IsAdmin, ExpiryTimestamp = false, 0
local MenuVisible = true
local MainFrame = nil

local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.Transparency = 1
FOVCircle.Color = Colors.White
FOVCircle.Filled = false

-- Чистка ответа
local function CleanResponse(text)
    if not text then return "" end
    return text:gsub("<[^>]*>", ""):gsub("%s+", "")
end

local function FormatTime(seconds)
    if seconds <= 0 then return "00:00:00" end
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", h, m, s)
end

-- ИСПРАВЛЕННАЯ ПРОВЕРКА (Убрал возможные причины "ОШИБКИ")
local function VerifyKey(key)
    if key == "" then return "invalid" end
    
    local url = API_URL .. "?check=" .. tostring(key) .. "&hwid=" .. HWID .. "&cb=" .. math.random(1, 99999)
    local success, response = pcall(function() 
        return game:HttpGet(url) 
    end)
    
    if success and response then
        local clean = CleanResponse(response)
        
        if clean == "admin" then
            IsAdmin = true
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif clean:find("valid|") then
            local split = string.split(clean, "|")
            local timeVal = tonumber(split[2])
            if timeVal then
                ExpiryTimestamp = timeVal / 1000
                IsAdmin = false
                if canSave then writefile(KEY_FILE, key) end
                return "ok"
            end
        end
    end
    return "invalid"
end

function BuildMenu()
    if CoreGui:FindFirstChild("IlliaV3_Menu") then CoreGui.IlliaV3_Menu:Destroy() end
    local G = Instance.new("ScreenGui", CoreGui); G.Name = "IlliaV3_Menu"
    
    MainFrame = Instance.new("ScrollingFrame", G)
    MainFrame.Size = UDim2.new(0, 320, 0, 500); MainFrame.Position = UDim2.new(0.5, -160, 0.5, -250)
    MainFrame.BackgroundColor3 = Colors.BG; MainFrame.AutomaticCanvasSize = "Y"; MainFrame.ScrollBarThickness = 0; MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame)
    
    local L = Instance.new("UIListLayout", MainFrame); L.Padding = UDim.new(0, 10); L.HorizontalAlignment = "Center"
    Instance.new("UIPadding", MainFrame).PaddingTop = UDim.new(0, 15)

    local H = Instance.new("TextLabel", MainFrame); H.Size = UDim2.new(1, 0, 0, 50); H.Font = "GothamBold"; H.TextSize = 18
    H.Text = IsAdmin and "👑 ILLIA V3 ADMIN" or "👤 ILLIA V3 USER"
    H.BackgroundColor3 = IsAdmin and Colors.AdminGold or Colors.MainBlue; H.TextColor3 = IsAdmin and Colors.BG or Colors.White; Instance.new("UICorner", H)

    local TimerLabel = Instance.new("TextLabel", MainFrame); TimerLabel.Size = UDim2.new(0.9, 0, 0, 30); TimerLabel.TextColor3 = Colors.White; TimerLabel.BackgroundTransparency = 1; TimerLabel.Font = "GothamBold"

    -- Слайдеры и кнопки (Цвет заменен на оригинальный синий)
    local function AddToggle(name, prop)
        local B = Instance.new("TextButton", MainFrame)
        B.Size = UDim2.new(0.9, 0, 0, 45); B.Font = "GothamBold"; B.TextColor3 = Colors.White; B.TextSize = 14
        B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark
        B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
        Instance.new("UICorner", B)
        B.MouseButton1Click:Connect(function()
            Settings[prop] = not Settings[prop]
            B.Text = name .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
            B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Colors.Dark
            SaveSettings()
        end)
    end

    AddToggle("FOV Круг", "ShowFOV")
    AddToggle("ESP Игроки", "ESP_Enabled")

    local Out = Instance.new("TextButton", MainFrame); Out.Size = UDim2.new(0.9, 0, 0, 40); Out.BackgroundColor3 = Colors.LogoutRed; Out.Text = "LOGOUT"; Out.TextColor3 = Colors.White; Out.Font = "GothamBold"; Instance.new("UICorner", Out)
    Out.MouseButton1Click:Connect(function() G:Destroy(); FOVCircle.Visible = false; if canSave then pcall(function() delfile(KEY_FILE) end) end; ShowLogin() end)

    RunService.RenderStepped:Connect(function()
        if G.Parent then
            local remaining = IsAdmin and 999999 or (ExpiryTimestamp - os.time())
            TimerLabel.Text = IsAdmin and "СТАТУС: БЕССРОЧНО" or "ОСТАЛОСЬ: " .. FormatTime(remaining)
            FOVCircle.Visible = Settings.ShowFOV; FOVCircle.Radius = Settings.AimRadius; FOVCircle.Position = UserInputService:GetMouseLocation()
            if not IsAdmin and remaining <= 0 then G:Destroy(); ShowLogin() end
        end
    end)
end

function ShowLogin()
    if CoreGui:FindFirstChild("IlliaLogin") then CoreGui.IlliaLogin:Destroy() end
    local A = Instance.new("ScreenGui", CoreGui); A.Name = "IlliaLogin"
    local B = Instance.new("Frame", A); B.Size = UDim2.new(0, 320, 0, 240); B.Position = UDim2.new(0.5,-160,0.5,-120); B.BackgroundColor3 = Colors.BG; Instance.new("UICorner", B)
    
    local Title = Instance.new("TextLabel", B); Title.Size = UDim2.new(1, 0, 0, 50); Title.Text = "Здраствуйте! Спасибо что выбрали мой чит"; Title.TextColor3 = Colors.MainBlue; Title.BackgroundTransparency = 1; Title.Font = "GothamBold"; Title.TextSize = 13

    local I = Instance.new("TextBox", B); I.Size = UDim2.new(0.8,0,0,45); I.Position = UDim2.new(0.1,0,0.3,0); I.PlaceholderText = "Введите ключ..."; I.BackgroundColor3 = Colors.Dark; I.TextColor3 = Colors.White; Instance.new("UICorner", I)
    
    local S = Instance.new("TextButton", B); S.Size = UDim2.new(0.8,0,0,45); S.Position = UDim2.new(0.1,0,0.65,0); S.BackgroundColor3 = Colors.MainBlue; S.Text = "ВОЙТИ"; S.TextColor3 = Colors.White; Instance.new("UICorner", S)
    
    S.MouseButton1Click:Connect(function()
        S.Text = "ПРОВЕРКА..."
        local res = VerifyKey(I.Text)
        if res == "ok" then
            S.Text = "УСПЕШНО!"; S.BackgroundColor3 = Colors.SuccessGreen; task.wait(0.5); A:Destroy(); BuildMenu()
        else
            S.Text = "НЕВЕРНЫЙ КЛЮЧ"; S.BackgroundColor3 = Colors.LogoutRed; task.wait(1.5); S.Text = "ВОЙТИ"; S.BackgroundColor3 = Colors.MainBlue
        end
    end)
end

UserInputService.InputBegan:Connect(function(i, g)
    if i.KeyCode == Enum.KeyCode.Insert then 
        if MainFrame then
            MenuVisible = not MenuVisible
            MainFrame.Visible = MenuVisible
        end
    end
end)

if canSave and isfile(KEY_FILE) then
    if VerifyKey(readfile(KEY_FILE)) == "ok" then BuildMenu() else ShowLogin() end
else ShowLogin() end
