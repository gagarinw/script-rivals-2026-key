}

-- [[ ФУНКЦИЯ ТАЙМЕРА (ИСПРАВЛЕНА) ]] --
local function GetTimeLeft()
    if IsAdmin then return "БЕССРОЧНО" end
    if ExpiryTimestamp == 0 then return "Загрузка..." end
    
    -- Делим на 1000, если Apps Script шлет миллисекунды
    local expiryInSeconds = (ExpiryTimestamp > 2000000000000) and math.floor(ExpiryTimestamp / 1000) or ExpiryTimestamp
    local left = expiryInSeconds - os.time()
    
    if left <= 0 then return "ИСТЕК" end
    
    local d = math.floor(left/86400)
    local h = math.floor((left%86400)/3600)
    local m = math.floor((left%3600)/60)
    local s = math.floor(left%60)
    
    if d > 0 then
        return string.format("%dд %02dч %02dм", d, h, m)
    else
        return string.format("%02dч %02dм %02dс", h, m, s)
    end
end

local function VerifyKey(key)
    local success, result = pcall(function() 
        return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID) 
    end)

    if success then
        if result == "admin" then
            IsAdmin = true
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif result:find("valid") then
            local parts = string.split(result, "|")
            ExpiryTimestamp = tonumber(parts[2]) or 0
            IsAdmin = false
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        end
    end
    return "Неверный ключ!"
end

-- [[ ИНТЕРФЕЙС (ТВОЕ МЕНЮ) ]] --
local ActiveMenu, ShowLogin

function BuildMenu()
    local Gui = Instance.new("ScreenGui", CoreGui); Gui.Name = "IlliaV3_Menu"
    local Main = Instance.new("ScrollingFrame", Gui)
    Main.Size = UDim2.new(0, 280, 0, 400); Main.Position = UDim2.new(0.5, -140, 0.5, -200)
    Main.BackgroundColor3 = Colors.BG; Main.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Instance.new("UICorner", Main)

    local List = Instance.new("UIListLayout", Main); List.Padding = UDim.new(0, 10); List.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 45); Title.Text = IsAdmin and "👑 ADMIN" or "👤 USER"
    Title.BackgroundColor3 = IsAdmin and Colors.AdminGold or Colors.MainBlue
    Title.TextColor3 = IsAdmin and Color3.new(0,0,0) or Colors.White; Title.Font = Enum.Font.GothamBold; Instance.new("UICorner", Title)

    local TimerLabel = Instance.new("TextLabel", Main)
    TimerLabel.Size = UDim2.new(0.9, 0, 0, 20); TimerLabel.BackgroundTransparency = 1; TimerLabel.TextColor3 = Colors.White
    TimerLabel.Text = "До конца: " .. GetTimeLeft()

    local AimStatus = Instance.new("TextLabel", Main)
    AimStatus.Size = UDim2.new(0.9,0,0,30); AimStatus.BackgroundTransparency = 1
    AimStatus.TextSize = 14; AimStatus.Font = "GothamBold"

    local Logout = Instance.new("TextButton", Main)
    Logout.Size = UDim2.new(0.9, 0, 0, 35); Logout.BackgroundColor3 = Colors.LogoutRed; Logout.Text = "ВЫЙТИ (LOGOUT)"; Logout.TextColor3 = Colors.White; Instance.new("UICorner", Logout)
    
    Logout.MouseButton1Click:Connect(function() 
        if canSave then pcall(function() delfile(KEY_FILE) end) end
        Gui:Destroy(); ShowLogin() 
    end)

    -- Обновление таймера и статуса Аима
    task.spawn(function()
        while Gui.Parent do
            TimerLabel.Text = "До конца: " .. GetTimeLeft()
            AimStatus.Text = "ЗАХВАТ [" .. Settings.AimKey.Name .. "]: " .. (AimbotActive and "ВКЛ" or "ВЫКЛ")
            AimStatus.TextColor3 = AimbotActive and Color3.new(0,1,0) or Color3.new(1,0,0)
            task.wait(1)
        end
    end)

    return Gui
end

ShowLogin = function()
    if CoreGui:FindFirstChild("IlliaLogin") then CoreGui.IlliaLogin:Destroy() end
    local Auth = Instance.new("ScreenGui", CoreGui)
    local Box = Instance.new("Frame", Auth); Box.Size = UDim2.new(0, 300, 0, 250); Box.Position = UDim2.new(0.5,-150,0.5,-125); Box.BackgroundColor3 = Colors.BG; Instance.new("UICorner", Box)
    local Inp = Instance.new("TextBox", Box); Inp.Size = UDim2.new(0.8, 0, 0, 40); Inp.Position = UDim2.new(0.1, 0, 0.2, 0); Inp.PlaceholderText = "Введите ключ..."; Inp.TextColor3 = Colors.White; Inp.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", Inp)
    local Status = Instance.new("TextLabel", Box); Status.Size = UDim2.new(1,0,0,20); Status.Position = UDim2.new(0,0,0.4,0); Status.Text = ""; Status.TextColor3 = Colors.White; Status.BackgroundTransparency = 1
    local Go = Instance.new("TextButton", Box); Go.Size = UDim2.new(0.8,0,0,40); Go.Position = UDim2.new(0.1,0,0.6,0); Go.BackgroundColor3 = Colors.MainBlue; Go.Text = "ВОЙТИ"; Go.TextColor3 = Colors.White; Instance.new("UICorner", Go)
    
    Go.MouseButton1Click:Connect(function()
        Status.Text = "Проверка..."; local r = VerifyKey(Inp.Text)
        if r == "ok" then Auth:Destroy(); ActiveMenu = BuildMenu() else Status.Text = r; Status.TextColor3 = Color3.new(1,0,0) end
    end)
end

-- ЛОГИКА АИМБОТА
UserInputService.InputBegan:Connect(function(input, g)
    if not g and input.KeyCode == Settings.AimKey then
        AimbotActive = not AimbotActive
    end
end)

-- ЗАПУСК
if canSave and isfile(KEY_FILE) then
    if VerifyKey(readfile(KEY_FILE)) == "ok" then ActiveMenu = BuildMenu() else ShowLogin() end
else
    ShowLogin()
end
