-- [[ ФУНКЦИЯ ПОЛЗУНКА ]] --
local function CreateSlider(parent, text, min, max, default, isColor, callback)
    local Frame = Instance.new("Frame", parent)
    Frame.Size = UDim2.new(0.9, 0, 0, 45); Frame.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, 0, 0, 20); Label.Text = text; Label.TextColor3 = Color3.new(1,1,1); Label.BackgroundTransparency = 1; Label.Font = "Gotham"

    local Bar = Instance.new("Frame", Frame)
    Bar.Size = UDim2.new(1, 0, 0, 6); Bar.Position = UDim2.new(0, 0, 0.7, 0); Bar.BackgroundColor3 = Color3.fromRGB(40,40,40); Instance.new("UICorner", Bar)

    local Fill = Instance.new("Frame", Bar)
    Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0); Fill.BackgroundColor3 = isColor and Color3.fromHSV(0, 1, 1) or Color3.fromRGB(0, 120, 255); Instance.new("UICorner", Fill)

    local Btn = Instance.new("TextButton", Bar); Btn.Size = UDim2.new(1,0,1,0); Btn.BackgroundTransparency = 1; Btn.Text = ""

    local function Update(input)
        local per = math.clamp((input.Position.X - Bar.AbsolutePosition.X) / Bar.AbsoluteSize.X, 0, 1)
        Fill.Size = UDim2.new(per, 0, 1, 0)
        local val = min + (max - min) * per
        if isColor then
            Settings.ESP_Color = Color3.fromHSV(per, 1, 1)
            Fill.BackgroundColor3 = Settings.ESP_Color
            callback(Settings.ESP_Color)
        else
            val = math.round(val * 100) / 100
            Label.Text = text .. ": " .. val
            callback(val)
        end
    end

    local drag = false
    Btn.MouseButton1Down:Connect(function() drag = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType == Enum.UserInputType.MouseMovement then Update(i) end end)
end

-- [[ АИМ И ESP ]] --
local function GetClosest()
    local t = nil; local d = Settings.AimRadius
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos, vis = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
            if vis then
                local m = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if m < d then t = p.Character.HumanoidRootPart; d = m end
            end
        end
    end
    return t
end

local function ApplyChams(char)
    local hl = Instance.new("Highlight", char)
    hl.FillTransparency = 0.5; hl.OutlineTransparency = 0
    RunService.RenderStepped:Connect(function()
        hl.Enabled = Settings.ESP_Enabled
        hl.FillColor = Settings.ESP_Rainbow and Color3.fromHSV(tick()%5/5,1,1) or Settings.ESP_Color
    end)
end

-- [[ МЕНЮ ]] --
local function BuildMenu()
    local Gui = Instance.new("ScreenGui", CoreGui); Gui.Name = "IlliaV3"
    local Main = Instance.new("ScrollingFrame", Gui)
    Main.Size = UDim2.new(0, 300, 0, 400); Main.Position = UDim2.new(0.5, -150, 0.5, -200)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Main.AutomaticCanvasSize = "Y"; Main.ScrollBarThickness = 2
    Instance.new("UIListLayout", Main).HorizontalAlignment = "Center"

    local Title = Instance.new("TextLabel", Main); Title.Size = UDim2.new(1,0,0,50); Title.BackgroundColor3 = Color3.fromRGB(0,120,255); Title.Text = "ILLIA SYSTEM V3"; Title.TextColor3 = Color3.new(1,1,1); Title.Font = "GothamBold"

    local AimB = Instance.new("TextButton", Main); AimB.Size = UDim2.new(0.9,0,0,45); AimB.Text = "АИМ [E]: ВЫКЛ"; AimB.BackgroundColor3 = Color3.fromRGB(30,30,30); AimB.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", AimB)

    CreateSlider(Main, "Цвет ESP (Hue)", 0, 1, 0.6, true, function() end)
    CreateSlider(Main, "Размер FOV", 50, 400, Settings.AimRadius, false, function(v) Settings.AimRadius = v end)
    CreateSlider(Main, "Скорость наводки", 0.05, 0.65, Settings.Sensitivity, false, function(v) Settings.Sensitivity = v end)

    local EspBtn = Instance.new("TextButton", Main); EspBtn.Size = UDim2.new(0.9,0,0,40); EspBtn.Text = "ESP: ВКЛ"
    EspBtn.MouseButton1Click:Connect(function() Settings.ESP_Enabled = not Settings.ESP_Enabled EspBtn.Text = "ESP: "..(Settings.ESP_Enabled and "ВКЛ" or "ВЫКЛ") end)

    UserInputService.InputBegan:Connect(function(i, g)
        if not g and i.KeyCode.Name == Settings.AimKey then
            AimbotToggled = not AimbotToggled
            AimB.Text = "АИМ: "..(AimbotToggled and "ВКЛ" or "ВЫКЛ")
            AimB.TextColor3 = AimbotToggled and Color3.new(0,1,0) or Color3.new(1,1,1)
        end
    end)
end

