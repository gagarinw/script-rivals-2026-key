-- Функция для получения оставшегося времени
local function GetTimeLeft()
    if IsAdmin then return "БЕССРОЧНО" end
    if StartTime == 0 then return "24ч 00м" end
    
    local expireTime = StartTime + 86400 -- 24 часа в секундах
    local left = expireTime - os.time()
    
    if left <= 0 then return "ИСТЕК" end
    
    local hours = math.floor(left / 3600)
    local mins = math.floor((left % 3600) / 60)
    return string.format("%02dч %02dм", hours, mins)
end

-- Проверка ключа
local function VerifyKey(key)
    local success, result = pcall(function()
        return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID)
    end)
    
    if success then
        if result == "valid" then
            IsAdmin = false
            if canSave then
                writefile(KEY_FILE, key)
                -- Если файла времени нет, создаем его (первый вход)
                if not isfile(TIME_FILE) then
                    writefile(TIME_FILE, tostring(os.time()))
                    StartTime = os.time()
                else
                    StartTime = tonumber(readfile(TIME_FILE)) or os.time()
                end
                
                -- Проверка: не прошло ли 24 часа?
                if (os.time() - StartTime) >= 86400 then
                    delfile(KEY_FILE)
                    delfile(TIME_FILE)
                    return "Время ключа истекло!"
                end
            end
            return "ok"
        elseif result == "admin" then
            IsAdmin = true
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif result == "wrong_hwid" then 
            return "Ключ занят другим ПК!"
        end
    end
    return "Неверный ключ!"
end

-- Основное меню (сокращенно, добавь сюда свои слайдеры)
local function BuildMenu()
    local Gui = Instance.new("ScreenGui", CoreGui)
    local Main = Instance.new("Frame", Gui)
    Main.Size = UDim2.new(0, 260, 0, 300)
    Main.Position = UDim2.new(0.5, -130, 0.5, -150)
    Main.BackgroundColor3 = Colors.BG
    Instance.new("UICorner", Main)

    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 40)
    Title.Text = IsAdmin and "👑 ADMIN" or "👤 USER"
    Title.TextColor3 = Colors.White
    Title.BackgroundColor3 = IsAdmin and Colors.AdminGold or Colors.MainBlue
    Instance.new("UICorner", Title)

    local TimerLabel = Instance.new("TextLabel", Main)
    TimerLabel.Size = UDim2.new(1, 0, 0, 30)
    TimerLabel.Position = UDim2.new(0, 0, 0, 50)
    TimerLabel.Text = "До конца: " .. GetTimeLeft()
    TimerLabel.TextColor3 = Colors.White
    TimerLabel.BackgroundTransparency = 1

    -- Цикл обновления таймера
    task.spawn(function()
        while Gui.Parent do
            TimerLabel.Text = "До конца: " .. GetTimeLeft()
            if not IsAdmin and (os.time() - StartTime) >= 86400 then
                Gui:Destroy()
                if canSave then delfile(KEY_FILE) delfile(TIME_FILE) end
                -- Тут можно вызвать окно логина
            end
            task.wait(30)
        end
    end)
    
    -- Кнопка Logout
    local Logout = Instance.new("TextButton", Main)
    Logout.Size = UDim2.new(0.8, 0, 0, 30)
    Logout.Position = UDim2.new(0.1, 0, 0.8, 0)
    Logout.Text = "ВЫЙТИ (LOGOUT)"
    Logout.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    Logout.TextColor3 = Colors.White
    Instance.new("UICorner", Logout)
    
    Logout.MouseButton1Click:Connect(function()
        if canSave then
            if isfile(KEY_FILE) then delfile(KEY_FILE) end
            if isfile(TIME_FILE) then delfile(TIME_FILE) end
        end
        Gui:Destroy()
    end)

    return Gui
end

-- Логика запуска (авто-вход)
if canSave and isfile(KEY_FILE) then
