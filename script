-- [[ ПРОВЕРКА КЛЮЧА ]] --
local function VerifyKeyRemote(input)
    local success, result = pcall(function()
        return game:HttpGet(API_URL .. "?check=" .. tostring(input))
    end)
    if success then
        if result == "admin" then IsAdmin = true return "ok"
        elseif result == "valid" then IsAdmin = false return "ok" end
    end
    return "fail"
end

-- [[ ФУНКЦИЯ СОЗДАНИЯ ПОЛЗУНКА ]] --
local function CreateSlider(parent, text, prop, min, max, adminOnly)
    local SliderBG = Instance.new("Frame", parent)
    SliderBG.Size = UDim2.new(0.9, 0, 0, 45)
    SliderBG.BackgroundTransparency = 1

    local Label = Instance.new("TextLabel", SliderBG)
    Label.Size = UDim2.new(1, 0, 0, 20)
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.new(1,1,1)
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamBold
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local Tray = Instance.new("Frame", SliderBG)
    Tray.Size = UDim2.new(1, 0, 0, 6)
    Tray.Position = UDim2.new(0, 0, 0.7, 0)
    Tray.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", Tray)

    local Fill = Instance.new("Frame", Tray)
    Fill.Size = UDim2.new((Settings[prop] - min) / (max - min), 0, 1, 0)
    Fill.BackgroundColor3 = adminOnly and Colors.AdminGold or Colors.MainBlue
    Instance.new("UICorner", Fill)

    local function update(input)
        if adminOnly and not IsAdmin then return end
        local pos = math.clamp((input.Position.X - Tray.AbsolutePosition.X) / Tray.AbsoluteSize.X, 0, 1)
        Fill.Size = UDim2.new(pos, 0, 1, 0)
        local val = math.round((min + (max - min) * pos) * 100) / 100
        Settings[prop] = val
        Label.Text = text .. ": " .. tostring(val)
    end

    local dragging = false
    Tray.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1) and not (adminOnly and not IsAdmin) then
            dragging = true
            update(input)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
    end)

    if adminOnly and not IsAdmin then
        Label.Text = text .. " [🔒 ADMIN]"
        Fill.BackgroundColor3 = Colors.LockedGrey
    else
        Label.Text = text .. ": " .. tostring(Settings[prop])
    end
end

