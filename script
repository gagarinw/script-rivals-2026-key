-- [[ ФУНКЦИЯ ПРОВЕРКИ ]] --
local function VerifyKeyRemote(input)
    local success, result = pcall(function()
        return game:HttpGet(API_URL .. "?check=" .. tostring(input))
    end)
    
    if success then
        if result == "admin" then
            IsAdmin = true
            return "ok"
        elseif result == "valid" then
            IsAdmin = false
            return "ok"
        elseif result == "expired_or_used" then
            return "used"
        end
    end
    return "fail"
end

