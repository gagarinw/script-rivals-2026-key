local canSave = (isfile and readfile and writefile and delfile)
local KEY_FILE = "illia_v3_key.txt"
local SETTINGS_FILE = "illia_v3_settings.json"

local Settings = {
    AimbotEnabled = true,
    AimRadius = 150,
    Sensitivity = 0.1,
    AimKey = "E",
    ShowFOV = true,
    ESP_Enabled = true,
    ESP_Rainbow = false,
    ESP_Hue = 0.6
}

local function SaveSettings()
    if canSave then writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings)) end
end

local function LoadSettings()
    if canSave and isfile(SETTINGS_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
        if success then for k, v in pairs(data) do Settings[k] = v end end
    end
end

LoadSettings()

