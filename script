-- [[ ЛОГИКА АИМБОТА ]] --
local function GetClosestPlayer()
    local target = nil
    local dist = Settings.AimRadius
    
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(Settings.AimPart) and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character[Settings.AimPart].Position)
            if onScreen then
                local magnitude = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                if magnitude < dist then
                    target = v
                    dist = magnitude
                end
            end
        end
    end
    return target
end

-- [[ КРУГ FOV ]] --
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.Color = Color3.new(1, 1, 1)
FOVCircle.Filled = false

-- [[ ГЛАВНЫЙ ЦИКЛ ]] --
RunService.RenderStepped:Connect(function()
    if not MainGui.Enabled then 
        FOVCircle.Visible = false 
        return 
    end

    -- Настройка FOV
    FOVCircle.Visible = Settings.ShowFOV
    FOVCircle.Radius = Settings.AimRadius
    FOVCircle.Position = UserInputService:GetMouseLocation()

    -- Логика ESP
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if p.Character and Settings.ESP_Enabled then
                local highlight = p.Character:FindFirstChild("IlliaHighlight")
                if not highlight then
                    highlight = Instance.new("Highlight")
                    highlight.Name = "IlliaHighlight"
                    highlight.Parent = p.Character
                end
                highlight.Enabled = true
                highlight.FillColor = Settings.ESP_Rainbow and Color3.fromHSV((tick() * 0.5) % 1, 0.8, 1) or Color3.fromHSV(Settings.ESP_Hue, 0.8, 1)
                highlight.FillTransparency = 0.5
                highlight.OutlineColor = Color3.new(1,1,1)
            else
                if p.Character and p.Character:FindFirstChild("IlliaHighlight") then
                    p.Character.IlliaHighlight.Enabled = false
                end
            end
        end
    end

    -- Логика Аимбота (нажатие правой кнопки мыши)
    if Settings.AimbotEnabled and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local target = GetClosestPlayer()
        if target and target.Character then
            local targetPos = target.Character[Settings.AimPart].Position
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, targetPos), Settings.Sensitivity)
        end
    end
end)

