-- [[ ЛОГИКА ПРОВЕРКИ КЛЮЧА ]] --
KeyBtn.MouseButton1Click:Connect(function()
    KeyBtn.Text = "CONNECTING..."
    KeyBtn.Active = false
    
    local status = VerifyKeyRemote(KeyInput.Text)
    
    if status == "ok" then
        KeyBtn.Text = IsAdmin and "WELCOME ADMIN" or "ACCESS GRANTED"
        KeyBtn.BackgroundColor3 = IsAdmin and Colors.AdminGold or Color3.fromRGB(0, 200, 100)
        task.wait(1)
        
        if IsAdmin then
            AdminBtn.Visible = true
            Title.Text = "ILLIA V3 [ADMIN]"
        end
        
        MainSystemGui:Destroy()
        MainGui.Enabled = true
    elseif status == "used" then
        KeyBtn.Text = "KEY ALREADY USED"
        KeyBtn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
        task.wait(2)
        KeyBtn.Text = "ПРОВЕРИТЬ КЛЮЧ"
        KeyBtn.Active = true
    else
        KeyBtn.Text = "INVALID KEY"
        KeyBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        task.wait(2)
        KeyBtn.Text = "ПРОВЕРИТЬ КЛЮЧ"
        KeyBtn.Active = true
    end
end)

