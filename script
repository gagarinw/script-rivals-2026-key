    CreateSlider(Main, "Цвет ESP (Радуга)", 0, 1, 0.6, true, function(c) Settings.ESP_Color = c end)
    CreateSlider(Main, "Радиус FOV", 50, 400, Settings.AimRadius, false, function(v) Settings.AimRadius = v end)
    CreateSlider(Main, "Сенса (Скорость)", 0.01, 0.65, Settings.Sensitivity, false, function(v) Settings.Sensitivity = v end)

    local fovT = Instance.new("TextButton", Main); fovT.Size = UDim2.new(0.9,0,0,40); fovT.Text = "Показать FOV: ВКЛ"
    fovT.MouseButton1Click:Connect(function() Settings.ShowFOV = not Settings.ShowFOV fovT.Text = "Показать FOV: "..(Settings.ShowFOV and "ВКЛ" or "ВЫКЛ") end)

    UserInputService.InputBegan:Connect(function(i, g)
        if not g and i.KeyCode.Name == Settings.AimKey then
            AimbotToggled = not AimbotToggled
