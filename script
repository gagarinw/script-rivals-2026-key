local function ShowLogin()
    local Auth = Instance.new("ScreenGui", CoreGui)
    local Box = Instance.new("Frame", Auth); Box.Size = UDim2.new(0, 300, 0, 160); Box.Position = UDim2.new(0.5,-150,0.5,-80); Box.BackgroundColor3 = Color3.fromRGB(25,25,25)
    local Inp = Instance.new("TextBox", Box); Inp.Size = UDim2.new(0.8,0,0,40); Inp.Position = UDim2.new(0.1,0,0.2,0); Inp.PlaceholderText = "Введите ключ..."
    local Go = Instance.new("TextButton", Box); Go.Size = UDim2.new(0.8,0,0,40); Go.Position = UDim2.new(0.1,0,0.6,0); Go.Text = "ВОЙТИ"
    Go.MouseButton1Click:Connect(function()
        local ok, res = pcall(function() return game:HttpGet(API_URL.."?check="..Inp.Text.."&hwid="..HWID) end)
        if ok and (res == "admin" or res:find("valid")) then Auth:Destroy(); BuildMenu() else Inp.Text = "НЕВЕРНО" end
    end)
end

