-- [[ ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ]] --
local function SaveConfig()
    if canSave then pcall(function() writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings)) end) end
end

local function LoadConfig()
    if canSave and isfile(SETTINGS_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
        if success then for k, v in pairs(data) do Settings[k] = v end end
    end
end

local function GetTimeLeft()
    if IsAdmin then return "БЕССРОЧНО" end
    if StartTime == 0 then return "24ч 00м 00с" end
    local left = (StartTime + 86400) - os.time()
    if left <= 0 then return "ИСТЕК" end
    local h = math.floor(left/3600)
    local m = math.floor((left%3600)/60)
    local s = math.floor(left%60)
    return string.format("%02dч %02dм %02dс", h, m, s)
end

local function VerifyKey(key)
    local success, result = pcall(function() return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID) end)
    if success then
        if result == "valid" or result == "admin" then
            IsAdmin = (result == "admin")
            if canSave then
                writefile(KEY_FILE, key)
                if not IsAdmin then
                    if not isfile(TIME_FILE) then writefile(TIME_FILE, tostring(os.time())) end
                    StartTime = tonumber(readfile(TIME_FILE)) or os.time()
                end
            end
            return "ok"
        end
    end
    return "Неверный ключ!"
end

-- [[ ИНТЕРФЕЙС ]] --
local ActiveMenu, AimStatusLabel, ShowLogin

local function CreateSlider(parent, text, prop, min, max)
    local Frame = Instance.new("Frame", parent)
    Frame.Size = UDim2.new(0.9, 0, 0, 45); Frame.BackgroundTransparency = 1
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, 0, 0, 20); Label.Text = text .. ": " .. Settings[prop]
    Label.TextColor3 = Colors.White; Label.BackgroundTransparency = 1; Label.Font = Enum.Font.GothamBold; Label.TextSize = 12
    local Slider = Instance.new("Frame", Frame)
    Slider.Size = UDim2.new(1, 0, 0, 6); Slider.Position = UDim2.new(0,0,0.7,0); Slider.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
    Instance.new("UICorner", Slider)
    local Fill = Instance.new("Frame", Slider); Fill.Size = UDim2.new((Settings[prop]-min)/(max-min), 0, 1, 0); Fill.BackgroundColor3 = Colors.MainBlue
    Slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local conn; conn = UserInputService.InputChanged:Connect(function(m)
                if m.UserInputType == Enum.UserInputType.MouseMovement then
                    local p = math.clamp((m.Position.X - Slider.AbsolutePosition.X) / Slider.AbsoluteSize.X, 0, 1)
                    Fill.Size = UDim2.new(p, 0, 1, 0)
                    Settings[prop] = math.round((min + (max-min)*p)*100)/100
                    Label.Text = text .. ": " .. Settings[prop]
                    SaveConfig()
                end
            end)
            UserInputService.InputEnded:Connect(function(up) if up.UserInputType == Enum.UserInputType.MouseButton1 then conn:Disconnect() end end)
        end
    end)
end

function BuildMenu()
    LoadConfig()
    local Gui = Instance.new("ScreenGui", CoreGui); Gui.Name = "IlliaV3_Main"
    local Main = Instance.new("ScrollingFrame", Gui)
    Main.Size = UDim2.new(0, 280, 0, 400); Main.Position = UDim2.new(0.5, -140, 0.5, -200)
    Main.BackgroundColor3 = Colors.BG; Main.BorderSizePixel = 0; Main.ScrollBarThickness = 3
    Instance.new("UICorner", Main)

    local List = Instance.new("UIListLayout", Main); List.Padding = UDim.new(0, 10); List.HorizontalAlignment = Enum.HorizontalAlignment.Center
    List:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() Main.CanvasSize = UDim2.new(0, 0, 0, List.AbsoluteContentSize.Y + 20) end)

    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 45); Title.Text = IsAdmin and "👑 ADMIN" or "👤 USER"
    Title.TextColor3 = IsAdmin and Color3.new(0,0,0) or Colors.White; Title.BackgroundColor3 = IsAdmin and Colors.AdminGold or Colors.MainBlue
    Title.Font = Enum.Font.GothamBold

    local TimerLabel = Instance.new("TextLabel", Main)
    TimerLabel.Size = UDim2.new(0.9, 0, 0, 20); TimerLabel.BackgroundTransparency = 1
    TimerLabel.TextColor3 = Color3.fromRGB(180,180,180); TimerLabel.Text = "До конца: " .. GetTimeLeft()

    AimStatusLabel = Instance.new("TextLabel", Main)
    AimStatusLabel.Size = UDim2.new(0.9,0,0,20); AimStatusLabel.BackgroundTransparency = 1
    AimStatusLabel.Text = "ЗАХВАТ [E]: ВЫКЛ"; AimStatusLabel.TextColor3 = Color3.new(1,0,0); AimStatusLabel.Font = Enum.Font.GothamBold

    local function Toggle(text, prop)
        local B = Instance.new("TextButton", Main); B.Size = UDim2.new(0.9, 0, 0, 35); B.Font = Enum.Font.GothamBold; B.TextColor3 = Colors.White
        local function up() B.Text = text .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ"); B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Color3.fromRGB(40,40,40) end
        B.MouseButton1Click:Connect(function() Settings[prop] = not Settings[prop]; up(); SaveConfig() end); up(); Instance.new("UICorner", B)
    end

    Toggle("Аимбот", "AimbotEnabled")
    CreateSlider(Main, "Радиус", "AimRadius", 50, 800)
    CreateSlider(Main, "Плавность", "Sensitivity", 0.01, 1)
    Toggle("ESP Игроки", "ESP_Enabled")
    Toggle("Радуга ESP", "ESP_Rainbow")
    Toggle("FOV Круг", "ShowFOV")

    local Logout = Instance.new("TextButton", Main)
    Logout.Size = UDim2.new(0.9, 0, 0, 35); Logout.BackgroundColor3 = Colors.LogoutRed
    Logout.Text = "ВЫЙТИ (LOGOUT)"; Logout.TextColor3 = Colors.White; Logout.Font = Enum.Font.GothamBold; Instance.new("UICorner", Logout)
    Logout.MouseButton1Click:Connect(function() 
        if canSave then pcall(function() delfile(KEY_FILE) delfile(TIME_FILE) end) end
        Gui:Destroy(); AimbotActive = false; ShowLogin() 
    end)

    -- ЖИВОЙ ТАЙМЕР
    task.spawn(function()
        while Gui.Parent do
            TimerLabel.Text = "До конца: " .. GetTimeLeft()
            if not IsAdmin and StartTime ~= 0 and (os.time() - StartTime) >= 86400 then
                if canSave then pcall(function() delfile(KEY_FILE) delfile(TIME_FILE) end) end
                Gui:Destroy(); ShowLogin(); break
            end
            task.wait(1)
        end
    end)

    return Gui
end

-- [[ АИМ / ESP ЦИКЛ ]] --
local Circle = Drawing.new("Circle"); Circle.Thickness = 1; Circle.Color = Colors.White
RunService.RenderStepped:Connect(function()
    Circle.Visible = Settings.ShowFOV; Circle.Radius = Settings.AimRadius; Circle.Position = UserInputService:GetMouseLocation()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChild("Highlight")
            if Settings.ESP_Enabled and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
                if not h then h = Instance.new("Highlight", p.Character) end
                h.Enabled = true; h.FillColor = Settings.ESP_Rainbow and Color3.fromHSV((tick()*0.5)%1, 0.8, 1) or Color3.fromHSV(Settings.ESP_Hue, 0.8, 1)
            elseif h then h.Enabled = false end
        end
    end
    if Settings.AimbotEnabled and AimbotActive then
        local target, closest = nil, Settings.AimRadius
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                local pos, vis = Camera:WorldToViewportPoint(v.Character.Head.Position)
                if vis then
                    local mag = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                    if mag < closest then target = v; closest = mag end
                end
            end
        end
        if target then
            local tPos = Camera:WorldToViewportPoint(target.Character.Head.Position)
            local mPos = UserInputService:GetMouseLocation()
            mousemoverel((tPos.X - mPos.X) * Settings.Sensitivity, (tPos.Y - mPos.Y) * Settings.Sensitivity)
        end
    end
end)

