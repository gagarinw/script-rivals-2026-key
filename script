-- [[ НАСТРОЙКИ ]] --
local Settings = {
    AimbotEnabled = true,
    AimKey = "E",
    AimRadius = 150,
    Sensitivity = 0.25,
    ESP_Enabled = false,
    ESP_Rainbow = false,
    ShowFOV = true
}

local AimbotToggled = false
local FOVCircle = Drawing.new("Circle")

-- [[ ФУНКЦИИ ОБНОВЛЕНИЯ FOV ]] --
local function UpdateFOV()
    FOVCircle.Visible = Settings.ShowFOV
    FOVCircle.Radius = Settings.AimRadius
    FOVCircle.Color = Color3.fromRGB(255, 255, 255)
    FOVCircle.Thickness = 1
    FOVCircle.Filled = false
    FOVCircle.Transparency = 1
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
end

-- [[ ЛОГИКА ESP ]] --
local function CreateESP(player)
    local Box = Drawing.new("Square")
    Box.Visible = false
    Box.Color = Color3.fromRGB(255, 255, 255)
    Box.Thickness = 1
    Box.Filled = false

    local function Update()
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and Settings.ESP_Enabled and player ~= LocalPlayer then
                local pos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                if onScreen then
                    local size = (Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position - Vector3.new(0, 3, 0)).Y - Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position + Vector3.new(0, 2.6, 0)).Y)
                    Box.Size = Vector2.new(size * 0.6, size)
                    Box.Position = Vector2.new(pos.X - Box.Size.X / 2, pos.Y - Box.Size.Y / 2)
                    Box.Visible = true
                    
                    if Settings.ESP_Rainbow then
                        Box.Color = Color3.fromHSV(tick() % 5 / 5, 1, 1)
                    else
                        Box.Color = Color3.fromRGB(255, 255, 255)
                    end
                else
                    Box.Visible = false
                end
            else
                Box.Visible = false
                if not player.Parent then 
                    Box:Remove()
                    connection:Disconnect()
                end
            end
        end)
    end
    coroutine.wrap(Update)()
end

for _, v in pairs(Players:GetPlayers()) do CreateESP(v) end
Players.PlayerAdded:Connect(CreateESP)

-- [[ ИНТЕРФЕЙС С НОВЫМИ КНОПКАМИ ]] --
local function BuildMenu()
    if CoreGui:FindFirstChild("IlliaV3_Menu") then CoreGui.IlliaV3_Menu:Destroy() end
    local Gui = Instance.new("ScreenGui", CoreGui); Gui.Name = "IlliaV3_Menu"
    local Main = Instance.new("ScrollingFrame", Gui)
    Main.Size = UDim2.new(0, 280, 0, 400); Main.Position = UDim2.new(0.5, -140, 0.5, -200)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Main.AutomaticCanvasSize = "Y"; Main.CanvasSize = UDim2.new(0,0,0,0)
    Instance.new("UICorner", Main); local list = Instance.new("UIListLayout", Main); list.Padding = UDim.new(0,10); list.HorizontalAlignment = "Center"

    local Title = Instance.new("TextLabel", Main); Title.Size = UDim2.new(1,0,0,45); Title.BackgroundColor3 = Color3.fromRGB(0,120,255); Title.Text = "ILLIA SYSTEM V3"
    
    -- АИМ ВКЛ/ВЫКЛ
    local AimBtn = Instance.new("TextButton", Main); AimBtn.Size = UDim2.new(0.9,0,0,40); AimBtn.Text = "АИМ [E]: ВЫКЛ"
    UserInputService.InputBegan:Connect(function(i, g)
        if not g and i.KeyCode.Name == Settings.AimKey then
            AimbotToggled = not AimbotToggled
            AimBtn.Text = "АИМ ["..Settings.AimKey.."]: "..(AimbotToggled and "ВКЛ" or "ВЫКЛ")
            AimBtn.TextColor3 = AimbotToggled and Color3.new(0,1,0) or Color3.new(1,1,1)
        end
    end)

    -- ESP КНОПКИ
    local EspBtn = Instance.new("TextButton", Main); EspBtn.Size = UDim2.new(0.9,0,0,40); EspBtn.Text = "ESP: OFF"
    EspBtn.MouseButton1Click:Connect(function()
        Settings.ESP_Enabled = not Settings.ESP_Enabled
        EspBtn.Text = "ESP: "..(Settings.ESP_Enabled and "ON" or "OFF")
    end)

    local RainbowBtn = Instance.new("TextButton", Main); RainbowBtn.Size = UDim2.new(0.9,0,0,40); RainbowBtn.Text = "Rainbow ESP: OFF"
    RainbowBtn.MouseButton1Click:Connect(function()
        Settings.ESP_Rainbow = not Settings.ESP_Rainbow
        RainbowBtn.Text = "Rainbow ESP: "..(Settings.ESP_Rainbow and "ON" or "OFF")
    end)

    -- FOV КНОПКА
    local FovBtn = Instance.new("TextButton", Main); FovBtn.Size = UDim2.new(0.9,0,0,40); FovBtn.Text = "Показать FOV: ON"
    FovBtn.MouseButton1Click:Connect(function()
        Settings.ShowFOV = not Settings.ShowFOV
        FovBtn.Text = "Показать FOV: "..(Settings.ShowFOV and "ON" or "OFF")
    end)

    -- Ползунок радиуса (связан с FOV кругом)
    local function Slider(txt, val, min, max, cb)
        local b = Instance.new("TextButton", Main); b.Size = UDim2.new(0.9,0,0,40); b.Text = txt..": "..val
        b.MouseButton1Click:Connect(function()
            val = val + 50; if val > max then val = min end
            b.Text = txt..": "..val; cb(val)
        end)
    end

    Slider("Радиус", Settings.AimRadius, 50, 500, function(v) Settings.AimRadius = v UpdateFOV() end)
end

