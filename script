local TIME_FILE = "illia_v3_time.txt"
local SETTINGS_FILE = "illia_v3_settings.json"

local Settings = {
    AimbotEnabled = true,
    ESP_Enabled = true,
    ESP_Rainbow = false, 
    ESP_Hue = 0.6,       
    ShowFOV = false,     
    AimRadius = 150,     
    Sensitivity = 0.25, 
    MenuKey = Enum.KeyCode.Insert,
    AimKey = Enum.KeyCode.E        
}

local IsAdmin = false 
