-- [[ ФУНКЦИИ СОЗДАНИЯ ЭЛЕМЕНТОВ ]] --
local function AddToggle(text, prop, adminOnly)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Font = Enum.Font.GothamBold
    
    local function up()
        if adminOnly and not IsAdmin then
            btn.Text = text .. " [🔒 ADMIN]"
            btn.BackgroundColor3 = Colors.LockedGrey
        else
            btn.Text = text .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
            btn.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Color3.fromRGB(100, 40, 150)
        end
    end
    btn.MouseButton1Click:Connect(function()
        if not (adminOnly and not IsAdmin) then
            Settings[prop] = not Settings[prop]
            up()
        end
    end)
    up()
    Instance.new("UICorner", btn)
end

local function AddSlider(text, prop, min, max, adminOnly)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    
    local function up()
        if adminOnly and not IsAdmin then
            btn.Text = text .. " [🔒 ADMIN]"
            btn.BackgroundColor3 = Colors.LockedGrey
        else
            btn.Text = text .. ": " .. tostring(Settings[prop])
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        end
    end
    btn.MouseButton1Click:Connect(function()
        if not (adminOnly and not IsAdmin) then
            if Settings[prop] >= max then Settings[prop] = min else Settings[prop] = math.round((Settings[prop] + (max-min)/10)*100)/100 end
            up()
        end
    end)
    up()
    Instance.new("UICorner", btn)
end

