-- [[ ILLIA SYSTEM V3 - TOGGLE AIMBOT & SAVE SETTINGS ]] --

local API_URL = "https://script.google.com/macros/s/AKfycbyZuHTct49uHwi2Ukq3bClmQcbgSu_-y0ABZGn148EH1XbgFSTzF9MYzBxh8VKsIsMnnQ/exec"
local HttpService = game:GetService("HttpService")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local HWID = game:GetService("RbxAnalyticsService"):GetClientId()

local KEY_FILE = "illia_v3_key.txt"
local SETTINGS_FILE = "illia_v3_settings.json"
local canSave = (isfile and writefile and readfile)

-- [[ НАСТРОЙКИ ]] --
local Settings = {
    AimbotEnabled = true,
    AimKey = "E", -- Твой выбор
    AimRadius = 150,
    Sensitivity = 0.25,
    TeamCheck = true
}

local IsAdmin = false
local ExpiryTimestamp = 0
local AimbotToggled = false -- Состояние вкл/выкл

-- [[ ФУНКЦИИ СОХРАНЕНИЯ ]] --
local function SaveSettings()
    if canSave then
        writefile(SETTINGS_FILE, HttpService:JSONEncode(Settings))
    end
end

local function LoadSettings()
    if canSave and isfile(SETTINGS_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end)
        if success then
            for k, v in pairs(data) do Settings[k] = v end
        end
    end
end

-- [[ ЛОГИКА АВТОРИЗАЦИИ ]] --
local function VerifyKey(key)
    local success, result = pcall(function() 
        return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID) 
    end)

    if success then
        if result == "admin" then
            IsAdmin = true
            return "ok"
        elseif result:find("valid") then
            local parts = string.split(result, "|")
            ExpiryTimestamp = tonumber(parts[2]) or 0
            IsAdmin = false
            return "ok"
        end
    end
    return "Неверный ключ"
end

-- [[ ОСНОВНОЕ МЕНЮ ]] --
local function BuildMenu()
    local Gui = Instance.new("ScreenGui", CoreGui)
    local Main = Instance.new("Frame", Gui)
    Main.Size = UDim2.new(0, 260, 0, 300); Main.Position = UDim2.new(0.5, -130, 0.5, -150)
    Main.BackgroundColor3 = Color3.fromRGB(15,15,15); Instance.new("UICorner", Main)

    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 40); Title.TextColor3 = Color3.new(1,1,1)
    Title.Text = IsAdmin and "👑 ADMIN" or "👤 USER"
    Title.BackgroundColor3 = IsAdmin and Color3.fromRGB(255, 180, 0) or Color3.fromRGB(0, 120, 255)
    Instance.new("UICorner", Title)

    local StatusLabel = Instance.new("TextLabel", Main)
    StatusLabel.Size = UDim2.new(1, 0, 0, 40); StatusLabel.Position = UDim2.new(0, 0, 0.2, 0)
    StatusLabel.BackgroundTransparency = 1; StatusLabel.TextColor3 = Color3.new(1,1,1)
    
    -- Цикл обновления статуса
    task.spawn(function()
        while Gui.Parent do
            local stateText = AimbotToggled and "ВКЛЮЧЕН" or "ВЫКЛЮЧЕН"
            local stateColor = AimbotToggled and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
            StatusLabel.Text = "АИМ [" .. Settings.AimKey .. "]: " .. stateText
            StatusLabel.TextColor3 = stateColor
            task.wait(0.1)
        end
    end)
end

-- [[ ЛОГИКА АИМБОТА ]] --
local function GetClosestPlayer()
    local closest = nil
    local maxDist = Settings.AimRadius

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            -- Team Check
            if Settings.TeamCheck and v.Team == LocalPlayer.Team then continue end
            
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if dist < maxDist then
                    closest = v.Character.HumanoidRootPart
                    maxDist = dist
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if AimbotToggled and Settings.AimbotEnabled then
        local target = GetClosestPlayer()
        if target then
            local targetPos = Camera:WorldToViewportPoint(target.Position)
            mousemoverel(
                (targetPos.X - Camera.ViewportSize.X/2) * Settings.Sensitivity,
                (targetPos.Y - Camera.ViewportSize.Y/2) * Settings.Sensitivity
            )
        end
    end
end)

-- [[ ОБРАБОТКА НАЖАТИЯ (ВКЛ/ВЫКЛ) ]] --
UserInputService.InputBegan:Connect(function(input, g)
    if not g and input.KeyCode.Name == Settings.AimKey then
        AimbotToggled = not AimbotToggled -- Переключаем режим
    end
end)

-- [[ СТАРТ ]] --
LoadSettings()
local function ShowLogin()
    -- (Твой старый код окна логина, вызывающий BuildMenu при успехе)
    -- Для теста просто запустим меню:
    BuildMenu()
end

if canSave and isfile(KEY_FILE) then
    if VerifyKey(readfile(KEY_FILE)) == "ok" then BuildMenu() else ShowLogin() end
else
    ShowLogin()
end
