local API_URL = "https://script.google.com/macros/s/AKfycbywLlQYH4OIiGA0KYaIdqbYBYiOJ99bUmutzF_sSmcE3I5XIqoc3SVXcArKvejctI60wg/exec"
local HttpService = game:GetService("HttpService")

local canSave = (isfile and readfile and writefile and delfile)
local KEY_FILE = "illia_v3_key.txt"

local IsAdmin = false 
local ExpiryTimestamp = 0 
local AimbotActive = false
local CoreGui = game:GetService("CoreGui")
local HWID = game:GetService("RbxAnalyticsService"):GetClientId()

-- ПРОВЕРКА КЛЮЧА
local function VerifyKey(key)
    local ok, res = pcall(function() 
        return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID) 
    end)
    
    if ok then
        if res == "admin" then
            IsAdmin = true
            ExpiryTimestamp = 0 -- Для админа обнуляем, чтобы не было таймера
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif res:find("valid|") then
            local data = string.split(res, "|")
            ExpiryTimestamp = tonumber(data[2])
            IsAdmin = false
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif res == "expired" then return "Ключ истек!"
        elseif res == "wrong_hwid" then return "Чужой ПК!"
        end
    end
    return "Неверный ключ!"
end

local function GetTimeLeft()
    if IsAdmin then return "БЕССРОЧНО" end
    if ExpiryTimestamp == 0 then return "00ч 00м 00с" end
    
    local left = math.floor(ExpiryTimestamp / 1000) - os.time()
    if left <= 0 then return "ИСТЕК" end
    
    local h = math.floor(left/3600)
    local m = math.floor((left%3600)/60)
    local s = math.floor(left%60)
    return string.format("%02dч %02dм %02dс", h, m, s)
end

-- ИНТЕРФЕЙС
local ActiveMenu, ShowLogin

function BuildMenu()
    local Gui = Instance.new("ScreenGui", CoreGui)
    local Main = Instance.new("Frame", Gui)
    Main.Size = UDim2.new(0, 260, 0, 300)
    Main.Position = UDim2.new(0.5, -130, 0.5, -150)
    Main.BackgroundColor3 = Color3.fromRGB(15,15,15)
    
    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 40)
    Title.Text = IsAdmin and "👑 ILLIA ADMIN" or "👤 ILLIA USER"
    Title.BackgroundColor3 = IsAdmin and Color3.fromRGB(255,200,0) or Color3.fromRGB(0,120,255)
    
    local TimerLabel = Instance.new("TextLabel", Main)
    TimerLabel.Size = UDim2.new(1, 0, 0, 40)
    TimerLabel.Position = UDim2.new(0, 0, 0.2, 0)
    TimerLabel.BackgroundTransparency = 1
    TimerLabel.TextColor3 = Color3.new(1,1,1)
    
    -- Обновление таймера
    task.spawn(function()
        while Gui.Parent do
            TimerLabel.Text = "Осталось: " .. GetTimeLeft()
            if not IsAdmin and ExpiryTimestamp ~= 0 and (math.floor(ExpiryTimestamp / 1000) - os.time()) <= 0 then
                Gui:Destroy(); ShowLogin(); break
            end
            task.wait(1)
        end
    end)
    
    return Gui
end

ShowLogin = function()
    local Auth = Instance.new("ScreenGui", CoreGui)
    local Box = Instance.new("Frame", Auth)
    Box.Size = UDim2.new(0, 300, 0, 200)
    Box.Position = UDim2.new(0.5, -150, 0.5, -100)
    Box.BackgroundColor3 = Color3.fromRGB(20,20,20)
    
    local Inp = Instance.new("TextBox", Box)
    Inp.Size = UDim2.new(0.8, 0, 0, 40)
    Inp.Position = UDim2.new(0.1, 0, 0.3, 0)
    Inp.PlaceholderText = "Ключ..."
    
    local Go = Instance.new("TextButton", Box)
    Go.Size = UDim2.new(0.8, 0, 0, 40)
    Go.Position = UDim2.new(0.1, 0, 0.6, 0)
    Go.Text = "ВОЙТИ"
    Go.MouseButton1Click:Connect(function()
        local res = VerifyKey(Inp.Text)
        if res == "ok" then Auth:Destroy(); ActiveMenu = BuildMenu() end
    end)
end

-- Авто-вход
if canSave and isfile(KEY_FILE) then
    if VerifyKey(readfile(KEY_FILE)) == "ok" then ActiveMenu = BuildMenu() else ShowLogin() end
else
    ShowLogin()
end
