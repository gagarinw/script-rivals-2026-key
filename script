-- Функция глубокой очистки ответа (чтобы не было "Неверный ключ")
local function CleanResponse(text)
    if not text then return "" end
    -- Удаляет HTML-теги, пробелы и переносы строк
    local cleaned = text:gsub("<[^>]*>", ""):gsub("%s+", "")
    return cleaned
end

local function FormatTime(seconds)
    if seconds <= 0 then return "ИСТЕК" end
    local h = math.floor(seconds / 3600)
    local m = math.floor((seconds % 3600) / 60)
    local s = math.floor(seconds % 60)
    return string.format("%02d:%02d:%02d", h, m, s)
end

-- Функция проверки ключа
local function VerifyKey(key)
    local success, result = pcall(function()
        return game:HttpGet(API_URL .. "?check=" .. tostring(key) .. "&hwid=" .. HWID .. "&nocache=" .. math.random(1, 9999))
    end)
    
    if success then
        result = CleanResponse(result)
        
        if result == "admin" then
            IsAdmin = true
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        elseif result:find("valid|") then
            local data = string.split(result, "|")
            ExpiryTimestamp = tonumber(data[2]) / 1000
            IsAdmin = false
            if canSave then writefile(KEY_FILE, key) end
            return "ok"
        end
    end
    return "invalid"
end

-- Создание главного меню
function BuildMenu()
    if CoreGui:FindFirstChild("IlliaV3_Menu") then CoreGui.IlliaV3_Menu:Destroy() end
    local G = Instance.new("ScreenGui", CoreGui); G.Name = "IlliaV3_Menu"
    
    local MainFrame = Instance.new("ScrollingFrame", G)
    MainFrame.Size = UDim2.new(0, 320, 0, 500)
    MainFrame.Position = UDim2.new(0.5, -160, 0.5, -250)
    MainFrame.BackgroundColor3 = Settings.BG
    MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame)
    
    local L = Instance.new("UIListLayout", MainFrame); L.Padding = UDim.new(0, 12); L.HorizontalAlignment = "Center"
    Instance.new("UIPadding", MainFrame).PaddingTop = UDim.new(0, 15)

    local Header = Instance.new("TextLabel", MainFrame)
    Header.Size = UDim2.new(1, 0, 0, 55)
    Header.Text = IsAdmin and "👑 ILLIA V3 ADMIN" or "👤 ILLIA V3 USER"
    Header.BackgroundColor3 = Settings.MainBlue
    Header.TextColor3 = Color3.new(1,1,1)
    Header.Font = Enum.Font.GothamBold
    Header.TextSize = 20
    Instance.new("UICorner", Header)

    local TimerLabel = Instance.new("TextLabel", MainFrame)
    TimerLabel.Size = UDim2.new(0.9, 0, 0, 30)
    TimerLabel.BackgroundTransparency = 1
    TimerLabel.TextColor3 = Color3.new(1,1,1)
    TimerLabel.Font = Enum.Font.GothamBold
    TimerLabel.TextSize = 14

    local LogoutBtn = Instance.new("TextButton", MainFrame)
    LogoutBtn.Size = UDim2.new(0.9, 0, 0, 40)
    LogoutBtn.BackgroundColor3 = Settings.PurpleColor
    LogoutBtn.Text = "ВЫЙТИ"
    LogoutBtn.TextColor3 = Color3.new(1,1,1)
    LogoutBtn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", LogoutBtn)

    LogoutBtn.MouseButton1Click:Connect(function()
        if canSave then pcall(function() delfile(KEY_FILE) end) end
        G:Destroy()
        ShowLogin()
    end)

    RunService.RenderStepped:Connect(function()
        if G.Parent then
            if not IsAdmin then
                local remaining = ExpiryTimestamp - os.time()
                TimerLabel.Text = "ОСТАЛОСЬ: " .. FormatTime(remaining)
                if remaining <= 0 then G:Destroy(); ShowLogin() end
            else
                TimerLabel.Text = "СТАТУС: БЕССРОЧНО"
            end
        end
