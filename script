    BG = Color3.fromRGB(15, 15, 15)
}

-- [[ ФУНКЦИЯ ПРОВЕРКИ ]] --
local function VerifyKey(key)
    local success, result = pcall(function()
        return game:HttpGet(API_URL .. "?check=" .. key .. "&hwid=" .. HWID)
    end)
    if success then
        if result == "admin" then IsAdmin = true return "ok"
        elseif result == "valid" then IsAdmin = false return "ok"
        elseif result == "wrong_hwid" then return "Ключ занят другим ПК!"
        end
    end
    return "Неверный ключ!"
end

-- [[ СОЗДАНИЕ СЛАЙДЕРА ]] --
local function CreateSlider(parent, text, prop, min, max, adminOnly)
    local Frame = Instance.new("Frame", parent)
    Frame.Size = UDim2.new(0.9, 0, 0, 40)
    Frame.BackgroundTransparency = 1

    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, 0, 0, 15)
    Label.Text = text .. ": " .. Settings[prop]
    Label.TextColor3 = Color3.new(1,1,1)
    Label.BackgroundTransparency = 1
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local Slider = Instance.new("Frame", Frame)
    Slider.Size = UDim2.new(1, 0, 0, 4)
    Slider.Position = UDim2.new(0,0,0.7,0)
    Slider.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
    Instance.new("UICorner", Slider)

    local Fill = Instance.new("Frame", Slider)
    Fill.Size = UDim2.new((Settings[prop]-min)/(max-min), 0, 1, 0)
    Fill.BackgroundColor3 = adminOnly and Colors.AdminGold or Colors.MainBlue
    Instance.new("UICorner", Fill)

    if adminOnly and not IsAdmin then
        Label.Text = text .. " [🔒 ADMIN]"
        Fill.BackgroundColor3 = Colors.Locked
    else
        Slider.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local conn
                conn = UserInputService.InputChanged:Connect(function(m)
                    if m.UserInputType == Enum.UserInputType.MouseMovement then
                        local p = math.clamp((m.Position.X - Slider.AbsolutePosition.X) / Slider.AbsoluteSize.X, 0, 1)
                        Fill.Size = UDim2.new(p, 0, 1, 0)
                        local v = math.round((min + (max-min)*p)*100)/100
                        Settings[prop] = v
                        Label.Text = text .. ": " .. v
                    end
                end)
                UserInputService.InputEnded:Connect(function(up)
                    if up.UserInputType == Enum.UserInputType.MouseButton1 then conn:Disconnect() end
                end)
            end
        end)
    end
end

-- [[ ГЛАВНОЕ МЕНЮ ]] --
function BuildMenu()
    local Gui = Instance.new("ScreenGui", CoreGui)
    Gui.Name = "IlliaV3_Menu"
    
    local Main = Instance.new("ScrollingFrame", Gui)
    Main.Size = UDim2.new(0, 260, 0, 380)
    Main.Position = UDim2.new(0.5, -130, 0.5, -190)
    Main.BackgroundColor3 = Colors.BG
    Main.BorderSizePixel = 0
    Main.CanvasSize = UDim2.new(0,0,1.2,0)
    Main.ScrollBarThickness = 3
    Instance.new("UICorner", Main)

    local Title = Instance.new("TextLabel", Main)
    Title.Size = UDim2.new(1, 0, 0, 40)
    Title.BackgroundColor3 = IsAdmin and Colors.AdminGold or Color3.fromRGB(30,30,30)
    Title.Text = IsAdmin and "👑 ILLIA V3 ADMIN" or "👤 ILLIA V3 USER"
    Title.TextColor3 = IsAdmin and Color3.new(0,0,0) or Color3.new(1,1,1)
    Title.Font = Enum.Font.GothamBold
    Instance.new("UICorner", Title)

    local List = Instance.new("UIListLayout", Main)
    List.Padding = UDim.new(0, 10)
    List.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local function Toggle(text, prop, adminOnly)
        local B = Instance.new("TextButton", Main)
        B.Size = UDim2.new(0.9, 0, 0, 35)
        B.Font = Enum.Font.GothamBold
        local function up()
            if adminOnly and not IsAdmin then
                B.Text = text .. " [🔒 ADMIN]"
                B.BackgroundColor3 = Colors.Locked
            else
                B.Text = text .. ": " .. (Settings[prop] and "ВКЛ" or "ВЫКЛ")
                B.BackgroundColor3 = Settings[prop] and Colors.MainBlue or Color3.fromRGB(40,40,40)
            end
        end
        B.MouseButton1Click:Connect(function()
            if not (adminOnly and not IsAdmin) then Settings[prop] = not Settings[prop] up() end
        end)
        up()
        Instance.new("UICorner", B)
    end

    Toggle("Аимбот", "AimbotEnabled", false)
    CreateSlider(Main, "Радиус", "AimRadius", 50, 800, false)
    CreateSlider(Main, "Плавность", "Sensitivity", 0.01, 1, false)
    Toggle("ESP Игроки", "ESP_Enabled", false)
    Toggle("Радуга ESP", "ESP_Rainbow", true)
    Toggle("FOV Круг", "ShowFOV", true)

    return Gui
end

-- [[ ЛОГИКА АИМА И ESP ]] --
local Circle = Drawing.new("Circle")
Circle.Thickness = 1
Circle.Color = Color3.new(1,1,1)

RunService.RenderStepped:Connect(function()
    Circle.Visible = Settings.ShowFOV
    Circle.Radius = Settings.AimRadius
    Circle.Position = UserInputService:GetMouseLocation()

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local h = p.Character:FindFirstChild("Highlight")
            if Settings.ESP_Enabled and p.Character:FindFirstChild("HumanoidRootPart") then
                if not h then h = Instance.new("Highlight", p.Character) end
                h.Enabled = true
                h.FillColor = Settings.ESP_Rainbow and Color3.fromHSV((tick()*0.5)%1, 0.8, 1) or Color3.fromHSV(Settings.ESP_Hue, 0.8, 1)
            elseif h then h.Enabled = false end
        end
    end

    if Settings.AimbotEnabled and UserInputService:IsKeyDown(Settings.AimKey) then
        local target, closest = nil, Settings.AimRadius
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
                local pos, vis = Camera:WorldToViewportPoint(v.Character.Head.Position)
                if vis then
                    local mag = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                    if mag < closest then target = v closest = mag end
                end
            end
        end
        if target then
            local tPos = Camera:WorldToViewportPoint(target.Character.Head.Position)
            local mPos = UserInputService:GetMouseLocation()
            mousemoverel((tPos.X - mPos.X) * Settings.Sensitivity, (tPos.Y - mPos.Y) * Settings.Sensitivity)
        end
    end
end)

